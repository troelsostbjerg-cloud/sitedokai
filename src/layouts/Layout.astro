---
interface StructuredData {
  [key: string]: unknown;
}

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  structuredData?: StructuredData | StructuredData[];
  noindex?: boolean;
}

const {
  title,
  description = 'Er din hjemmeside synlig for AI? SitedokAI tester din synlighed på ChatGPT, Gemini, Google AI Overviews og Claude. 2.495 kr for 1 website og op til 5 nøglesider.',
  canonical = Astro.url.href,
  ogImage = '/og-image.png',
  structuredData,
  noindex = false,
} = Astro.props;

const siteUrl = Astro.site?.href ?? 'https://sitedokai.com/';
const canonicalUrl = canonical.startsWith('http') ? canonical : new URL(canonical, siteUrl).href;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : new URL(ogImage, siteUrl).href;
const ogImageType = ogImageUrl.endsWith('.png') ? 'image/png' : ogImageUrl.endsWith('.jpg') || ogImageUrl.endsWith('.jpeg') ? 'image/jpeg' : undefined;
const schemaBlocks = !structuredData ? [] : Array.isArray(structuredData) ? structuredData : [structuredData];
const robotsContent = noindex ? 'noindex, nofollow' : 'index, follow';
---

<!doctype html>
<html lang="da">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="SitedokAI" />
    <meta name="robots" content={robotsContent} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="SitedokAI" />
    <meta property="og:locale" content="da_DK" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    {ogImageType && <meta property="og:image:type" content={ogImageType} />}
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.bunny.net" />
    <link href="https://fonts.bunny.net/css?family=bricolage-grotesque:400,600,700,800&family=inter:400,500,600,700" rel="stylesheet" />
    {schemaBlocks.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
    <title>{title}</title>
  </head>
  <body class="bg-white">
    <slot />

    <!-- Cookie-information banner (kun tekniske cookies) -->
    <section id="cookie-banner" aria-label="Cookie-information" class="fixed bottom-0 left-0 right-0 bg-brand text-white px-6 py-4 z-50 border-t border-white/10 hidden">
      <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
        <p class="text-sm text-white/80">
          Vi bruger kun nødvendige tekniske cookies for at sikre at hjemmesiden fungerer korrekt. Ingen tracking, ingen markedsføring.
          <a href="/privatlivspolitik" class="text-accent-bright underline hover:text-accent-light">Læs mere</a>
        </p>
        <div class="flex gap-2 flex-shrink-0">
          <button id="cookie-decline" class="border border-white/30 text-white/80 px-4 py-2 text-sm font-bold hover:bg-white/10 transition-colors whitespace-nowrap">
            Afvis
          </button>
          <button id="cookie-accept" class="bg-amber-400 text-brand px-4 py-2 text-sm font-bold hover:bg-amber-300 transition-colors whitespace-nowrap">
            Acceptér
          </button>
        </div>
      </div>
    </section>

    <script is:inline>
      (function() {
        if (!localStorage.getItem('cookie-choice')) {
          document.getElementById('cookie-banner').classList.remove('hidden');
        }
        function hideBanner(choice) {
          localStorage.setItem('cookie-choice', choice);
          document.getElementById('cookie-banner').classList.add('hidden');
        }
        var accept = document.getElementById('cookie-accept');
        var decline = document.getElementById('cookie-decline');
        if (accept) accept.addEventListener('click', function() { hideBanner('accepted'); });
        if (decline) decline.addEventListener('click', function() { hideBanner('declined'); });
      })();
    </script>

    <script is:inline>
      document.addEventListener('submit', (event) => {
        const form = event.target;

        if (!(form instanceof HTMLFormElement)) return;

        const websiteInput = form.querySelector('input[name="website"]');

        if (!(websiteInput instanceof HTMLInputElement)) return;

        const value = websiteInput.value.trim();

        if (!value) return;

        if (!/^[a-zA-Z][a-zA-Z\d+\-.]*:\/\//.test(value)) {
          websiteInput.value = `https://${value.replace(/^\/+/, '')}`;
        }
      });
    </script>
  </body>
</html>

---
const features = [
  'AI-synlighed på 5 platforme (ChatGPT, Perplexity, Claude, Gemini, Google AI)',
  'Alle 10 tekniske tests (performance, sikkerhed, SEO, Core Web Vitals)',
  'Konkurrent-benchmark',
  'Kilde-analyse: hvorfor AI anbefaler andre',
  'Prioriterede handlingsanbefalinger',
];
---

<section id="pricing" class="bg-brand text-white">
  <div class="max-w-5xl mx-auto px-6 py-20 md:py-28">
    <div class="max-w-2xl mx-auto text-center mb-12">
      <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight mb-4">
        Én rapport. Alt du skal vide.
      </h2>
      <p class="text-lg text-white/50">
        Ingen abonnementer. Ingen opfølgning. Ingen skjulte gebyrer.
      </p>
    </div>

    <div class="max-w-lg mx-auto bg-brand-light p-8 md:p-10 ring-2 ring-accent ring-inset">
      <div class="text-sm font-bold text-white/80 mb-3">SitedokAI Rapport</div>
      <div class="font-display text-4xl md:text-5xl font-extrabold text-white mb-1">2.495 kr</div>
      <div class="text-sm text-white/40 mb-8">Engangskøb</div>

      <ul class="space-y-3 mb-8">
        {features.map((feature) => (
          <li class="flex items-start gap-3 text-sm text-white/60">
            <svg class="w-4 h-4 mt-0.5 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            {feature}
          </li>
        ))}
      </ul>

      <a
        href="#contact"
        class="block text-center py-4 px-6 font-bold text-lg bg-accent text-brand hover:bg-accent-light transition-colors"
      >
        Bestil rapport
      </a>
    </div>
  </div>
</section>

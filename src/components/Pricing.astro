---
const features = [
  'AI-synlighed på 5 platforme: ChatGPT, Perplexity, Claude, Gemini og Google AI',
  'Gennemgang af 1 website og op til 5 nøglesider',
  'Teknisk baseline: performance, SEO og indeksérbarhed',
  'Kort PDF med score, fund og 3 prioriterede forbedringer',
  'Levering inden for 48 timer på hverdage',
  'Ingen implementering og ingen løbende rådgivning',
];
---

<section id="pricing" class="bg-brand text-white">
  <div class="max-w-5xl mx-auto px-6 py-20 md:py-28">
    <div class="max-w-2xl mx-auto text-center mb-12">
      <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight mb-4">
        Introtilbud til lancering
      </h2>
      <p class="text-lg text-white/50">
        495 kr i 14 dage, med klart scope og hurtig levering.
      </p>
    </div>

    <div class="max-w-lg mx-auto bg-brand-light p-8 md:p-10 ring-2 ring-accent ring-inset">
      <div class="text-sm font-bold text-white/80 mb-3">SitedokAI Introtilbud</div>
      <div class="font-display text-4xl md:text-5xl font-extrabold text-white mb-1">495 kr</div>
      <div class="text-sm text-white/40 mb-2">Engangsbetaling</div>
      <div class="text-sm text-accent mb-8">Gælder i 14 dage fra lancering</div>

      <ul class="space-y-3 mb-8">
        {features.map((feature) => (
          <li class="flex items-start gap-3 text-sm text-white/60">
            <svg class="w-4 h-4 mt-0.5 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            {feature}
          </li>
        ))}
      </ul>

      <a
        href="#contact"
        class="block text-center py-4 px-6 font-bold text-lg bg-accent text-brand hover:bg-accent-light transition-colors"
      >
        Bestil introtilbud
      </a>
    </div>
  </div>
</section>

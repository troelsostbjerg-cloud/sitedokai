---
const features = [
  'AI-synlighed på 4 AI-platforme: ChatGPT, Gemini, Google AI Overviews og Claude',
  'Gennemgang af 1 website og op til 5 nøglesider',
  'Teknisk baseline for performance, SEO, struktur og indekserbarhed',
  'Dansk PDF med score, fund og prioriterede forbedringer',
  'Levering inden for 48 timer på hverdage',
  'Ingen abonnement, ingen binding og ingen efterfølgende mødekrav',
];

const trustBullets = [
  'Fast pris, 2.495 kr',
  'Sikker betaling via Stripe',
  'Bestillingsmail fra info@sitedokai.com',
];
---

<section id="pricing" class="bg-brand text-white">
  <div class="max-w-5xl mx-auto px-6 py-20 md:py-28">
    <div class="max-w-2xl mx-auto text-center mb-12">
      <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight mb-4">
        AI-synlighedsrapport til 2.495 kr
      </h2>
      <p class="text-lg text-white/60 leading-relaxed">
        Én rapport, én fast pris og en konkret leverance. Du får indblik i hvad AI ser, hvor konkurrenterne slår dig, og hvad der skal forbedres først.
      </p>
    </div>

    <div class="max-w-xl mx-auto bg-brand-light p-8 md:p-10 ring-2 ring-accent ring-inset rounded-2xl">
      <div class="text-sm font-bold text-white/80 mb-3">SitedokAI Rapport</div>
      <div class="font-display text-4xl md:text-5xl font-extrabold text-white mb-1">2.495 kr</div>
      <div class="text-sm text-white/60 mb-8">Engangskøb, levering inden for 48 timer på hverdage</div>

      <ul class="space-y-3 mb-8">
        {features.map((feature) => (
          <li class="flex items-start gap-3 text-sm text-white/70">
            <svg class="w-4 h-4 mt-0.5 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            {feature}
          </li>
        ))}
      </ul>

      <a href="#contact" class="block text-center py-4 px-6 font-bold text-lg bg-amber-400 text-brand hover:bg-amber-300 transition-colors rounded-md mb-5">
        Bestil AI-synlighedsrapport for 2.495 kr
      </a>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
        {trustBullets.map((item) => (
          <div class="border border-white/10 bg-white/5 rounded-xl px-4 py-3 text-sm text-white/70 text-center">
            {item}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

---
const features = [
  'AI-synlighed testet på ChatGPT, Gemini, Codex og Google AI',
  'Gennemgang af 1 website og op til 5 nøglesider',
  'Teknisk baseline: performance, SEO og indeksérbarhed',
  'Interaktivt Client Room med overblik, konkurrentbillede og næste skridt',
  'PDF-eksport til intern deling og videre arbejde',
  'Levering inden for 48 timer på hverdage',
  'Ingen abonnement og ingen tung platform',
];
---

<section id="pricing" class="bg-brand text-white">
  <div class="max-w-5xl mx-auto px-6 py-20 md:py-28">
    <div class="max-w-2xl mx-auto text-center mb-12">
      <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight mb-4">
        AI-audit med Client Room
      </h2>
      <p class="text-lg text-white/50">
        Du får et klart beslutningsgrundlag uden at købe et langt bureauforløb eller en stor SaaS-løsning først.
      </p>
    </div>

    <div class="max-w-lg mx-auto bg-brand-light p-8 md:p-10 ring-2 ring-accent ring-inset">
      <div class="text-sm font-bold text-white/80 mb-3">SitedokAI Audit</div>
      <div class="flex items-baseline gap-3 mb-1">
        <span class="text-lg text-white/30 line-through">8.000+ kr/md</span>
        <span class="text-xs font-bold text-accent bg-accent/10 px-2 py-0.5 rounded-full">Lean start</span>
      </div>
      <div class="font-display text-4xl md:text-5xl font-extrabold text-white mb-1">2.495 kr</div>
      <div class="text-sm text-white/60 mb-8">Engangsbetaling — ingen abonnement</div>

      <ul class="space-y-3 mb-8">
        {features.map((feature) => (
          <li class="flex items-start gap-3 text-sm text-white/60">
            <svg class="w-4 h-4 mt-0.5 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            {feature}
          </li>
        ))}
      </ul>

      <a
        href="#contact"
        class="block text-center py-4 px-6 font-bold text-lg bg-amber-400 text-brand hover:bg-amber-300 transition-colors"
      >
        Bestil audit
      </a>
    </div>
  </div>
</section>

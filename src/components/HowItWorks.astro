---
const steps = [
  {
    num: '01',
    title: 'Bestil auditen',
    desc: 'Du sender navn, email og website, og går videre til sikker betaling via Stripe.',
  },
  {
    num: '02',
    title: 'Du gennemfører betalingen',
    desc: 'Du betaler sikkert via Stripe, og vi bruger oplysningerne fra formularen til at starte arbejdet.',
  },
  {
    num: '03',
    title: 'Vi gennemgår dit website',
    desc: 'Vi tester AI-synlighed på 4 platforme, gennemgår op til 5 nøglesider og laver teknisk baseline.',
  },
  {
    num: '04',
    title: 'Du modtager Client Room',
    desc: 'Inden for 48 timer på hverdage får du en mail med et privat link til dit Client Room. PDF følger med som eksport, og der er ikke login.',
  },
];

const trust = [
  'Ingen abonnement og ingen binding',
  'Manuel kvalitetssikring før leverancen sendes',
  'Trygt køb med sikker betaling og svar på mail',
];
---

<section id="how-it-works" class="bg-white border-b border-gray-200">
  <div class="max-w-5xl mx-auto px-6 py-20 md:py-28">
    <div class="max-w-3xl mb-16">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-brand tracking-tight mb-4">
        Hvad sker der efter bestilling?
      </h2>
      <p class="text-lg text-gray-500 leading-relaxed">
        Flowet er gjort enkelt med vilje. Du bestiller én audit, vi laver arbejdet, og du får en konkret leverance uden et langt konsulentforløb bagefter.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-10 md:gap-8 mb-12">
      {steps.map((step, i) => (
        <div class="relative">
          {i < steps.length - 1 && (
            <div class="hidden xl:block absolute top-8 left-full w-full h-px bg-gray-200 -translate-x-4" />
          )}
          <div class="font-display text-5xl font-extrabold text-gray-200 mb-4" aria-hidden="true">{step.num}</div>
          <h3 class="font-display text-lg font-bold text-brand mb-2">{step.title}</h3>
          <p class="text-sm text-gray-500 leading-relaxed">{step.desc}</p>
        </div>
      ))}
    </div>

    <div class="bg-gray-50 border border-gray-200 rounded-2xl p-6 md:p-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {trust.map((item) => (
          <div class="flex items-start gap-3 bg-white border border-gray-200 rounded-xl p-4 text-sm text-gray-600">
            <svg class="w-5 h-5 mt-0.5 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span>{item}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

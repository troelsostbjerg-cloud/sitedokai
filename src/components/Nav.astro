---
interface Props {
  variant?: 'light' | 'soft';
}

const { variant = 'light' } = Astro.props;
const isSoft = variant === 'soft';
---
<a
  href="#main"
  class:list={[
    'sr-only focus:not-sr-only focus:absolute focus:top-0 focus:left-0 focus:px-4 focus:py-3 focus:z-50',
    isSoft ? 'focus:bg-white focus:text-brand' : 'focus:bg-brand focus:text-white',
  ]}
>
  Gå til hovedindhold
</a>

<nav
  class:list={[
    'sticky top-0 z-50 border-b backdrop-blur-xl',
    isSoft
      ? 'border-[#ddd4c7] bg-[rgba(251,248,242,0.94)] text-brand'
      : 'border-[#e6ddd1] bg-[rgba(250,247,242,0.9)] text-brand',
  ]}
  role="navigation"
  aria-label="Hovednavigation"
>
  <div class="max-w-[1400px] mx-auto px-6 py-4 flex justify-between items-center gap-4">
    <a href="/" class="flex items-center gap-2 group">
      <svg viewBox="0 0 32 32" class="w-8 h-8" xmlns="http://www.w3.org/2000/svg">
        <circle cx="16" cy="16" r="16" fill="#f2e5d0" />
        <circle cx="16" cy="16" r="12.5" fill="none" stroke="#9f6a24" stroke-width="1.2" />
        <circle cx="16" cy="16" r="8" fill="none" stroke="#9f6a24" stroke-width="1" opacity="0.55" />
        <circle cx="16" cy="16" r="4" fill="#1f2a33" />
        <line x1="16" y1="3.5" x2="16" y2="16" stroke="#9f6a24" stroke-width="1" stroke-linecap="round" />
        <line x1="22.6" y1="9.4" x2="16" y2="16" stroke="#9f6a24" stroke-width="1" stroke-linecap="round" />
      </svg>
      <span class="font-display text-xl font-extrabold tracking-tight transition-colors text-brand group-hover:text-accent">
        SitedokAI
      </span>
    </a>
    <div class="hidden sm:flex items-center gap-3">
      <a href="/eksempel" class="rounded-md px-4 py-2 text-sm font-medium text-brand/68 transition-colors hover:bg-white hover:text-brand">
        Eksempel
      </a>
      <a href="/use-cases" class="rounded-md px-4 py-2 text-sm font-medium text-brand/68 transition-colors hover:bg-white hover:text-brand">
        Use cases
      </a>
      <a href="/om" class="rounded-md px-4 py-2 text-sm font-medium text-brand/68 transition-colors hover:bg-white hover:text-brand">
        Metode
      </a>
      <a href="/kontakt" class="rounded-md bg-brand px-5 py-2.5 text-sm font-bold whitespace-nowrap text-white transition-colors hover:bg-brand-light">
        Kontakt
      </a>
    </div>
    <button id="mobile-menu-btn" class="sm:hidden text-brand" aria-label="Menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
  <div id="mobile-menu" class="sm:hidden hidden border-t border-[#e6ddd1] bg-[#faf7f2] px-6 py-4 space-y-3">
    <a href="/eksempel" class="block text-sm font-medium text-brand/70 hover:text-brand">Eksempel</a>
    <a href="/use-cases" class="block text-sm font-medium text-brand/70 hover:text-brand">Use cases</a>
    <a href="/om" class="block text-sm font-medium text-brand/70 hover:text-brand">Metode</a>
    <a href="/kontakt" class="block rounded-md bg-brand px-5 py-2.5 text-center text-sm font-bold text-white transition-colors hover:bg-brand-light">
      Kontakt
    </a>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  if (btn && menu) {
    btn.addEventListener('click', () => menu.classList.toggle('hidden'));
    menu.querySelectorAll('a').forEach((link) => link.addEventListener('click', () => menu.classList.add('hidden')));
  }
</script>

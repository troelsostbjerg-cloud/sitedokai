---
import HeroAnimation from './HeroAnimation.astro';

const trustBullets = [
  'Fast pris på 2.495 kr, ingen abonnement og ingen binding',
  'Leveret som PDF inden for 48 timer på hverdage',
  'Bestilling, betaling og kvittering håndteres sikkert via Stripe og info@sitedokai.com',
];

const examplePoints = [
  'Samlet score på 32/100 og tydelig forklaring på hvorfor virksomheden ikke nævnes',
  'Platform-for-platform vurdering af ChatGPT, Gemini, Google AI Overviews og Claude',
  'Tre prioriterede forbedringer, så man ved hvad der skal fixes først',
];
---

<section class="relative overflow-hidden bg-brand text-white">
  <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle at 1px 1px, #06b6d4 1px, transparent 0); background-size: 48px 48px;"></div>

  <div class="relative max-w-5xl mx-auto px-6 py-20 md:py-28">
    <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-12 items-start">
      <div>
        <div class="inline-flex items-center gap-2 bg-white/10 border border-white/10 px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-accent-bright mb-6 backdrop-blur-sm">
          AI-synlighedsrapport til 2.495 kr
        </div>
        <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight leading-[1.1] mb-6 max-w-3xl text-white">
          Se om ChatGPT, Google AI og Gemini anbefaler din virksomhed før konkurrenten.
        </h1>
        <p class="text-lg md:text-xl text-white/70 mb-8 max-w-2xl leading-relaxed">
          SitedokAI tester dit website på tværs af 4 AI-platforme, gennemgår op til 5 nøglesider og leverer en dansk PDF med score, fund og prioriterede forbedringer.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 items-stretch sm:items-center mb-6">
          <a href="#contact" class="bg-amber-400 text-brand px-8 py-4 font-bold text-lg rounded-md hover:bg-amber-300 transition-colors text-center">
            Bestil AI-synlighedsrapport for 2.495 kr
          </a>
          <a href="/eksempel" class="border border-white/20 text-white/90 px-8 py-4 font-semibold text-lg rounded-md hover:border-white/50 hover:text-white transition-colors text-center">
            Se eksempelrapporten
          </a>
        </div>

        <ul class="space-y-3 max-w-2xl">
          {trustBullets.map((bullet) => (
            <li class="flex items-start gap-3 text-sm text-white/70">
              <svg class="w-5 h-5 mt-0.5 text-accent-bright flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>{bullet}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="bg-white text-brand rounded-3xl p-6 md:p-8 shadow-2xl shadow-black/20 border border-white/10">
        <div class="flex flex-wrap items-center justify-between gap-3 mb-6">
          <div>
            <div class="text-xs font-semibold uppercase tracking-wider text-accent mb-2">Eksempelrapport</div>
            <h2 class="font-display text-2xl md:text-3xl font-extrabold tracking-tight">Nordisk Køkken</h2>
            <p class="text-sm text-gray-500 mt-1">Fiktiv rapport, men samme struktur og detaljer som den rigtige leverance.</p>
          </div>
          <a href="/demo-rapport.html" class="text-sm font-bold text-accent hover:text-accent-light transition-colors">
            Åbn fuld PDF-rapport
          </a>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-[0.8fr_1.2fr] gap-4 mb-6">
          <div class="bg-gray-50 border border-gray-200 rounded-2xl p-5 text-center">
            <div class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-3">Samlet score</div>
            <div class="font-display text-6xl font-extrabold text-score-red leading-none mb-2">32</div>
            <div class="text-sm text-score-red font-bold bg-red-50 rounded-full px-3 py-1 inline-block">Lav synlighed</div>
            <p class="text-xs text-gray-500 mt-3">Konkurrenter nævnes oftere end virksomheden i AI-svar.</p>
          </div>
          <div class="bg-gray-50 border border-gray-200 rounded-2xl p-5">
            <div class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-4">Det viser rapporten</div>
            <ul class="space-y-3">
              {examplePoints.map((point) => (
                <li class="flex items-start gap-3 text-sm text-gray-600">
                  <span class="w-2 h-2 rounded-full bg-accent mt-2 flex-shrink-0"></span>
                  <span>{point}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3 mb-6">
          <div class="border border-gray-200 rounded-xl p-4">
            <div class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">ChatGPT</div>
            <div class="font-semibold text-brand mb-1">Ikke nævnt</div>
            <div class="text-xs text-gray-500">Relevant søgning ender med konkurrenten som anbefaling.</div>
          </div>
          <div class="border border-gray-200 rounded-xl p-4">
            <div class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Gemini</div>
            <div class="font-semibold text-brand mb-1">Forældet info</div>
            <div class="text-xs text-gray-500">Finder siden, men bruger gamle adresser og ældre indhold.</div>
          </div>
        </div>

        <a href="/eksempel" class="inline-flex items-center gap-2 text-sm font-bold text-brand hover:text-accent transition-colors">
          Se gennemgangen af eksempelrapporten
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>

    <HeroAnimation />
  </div>
</section>

---
---
<section class="relative overflow-hidden bg-brand text-white">
  <!-- Subtle radar grid pattern -->
  <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle at 1px 1px, #06b6d4 1px, transparent 0); background-size: 48px 48px;"></div>

  <div class="relative max-w-5xl mx-auto px-6 py-24 md:py-32 text-center">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 bg-white/10 text-accent-light text-sm font-medium px-4 py-1.5 mb-8 backdrop-blur-sm">
      <span class="w-2 h-2 bg-accent rounded-full animate-pulse"></span>
      AI-synlighed + Website Performance
    </div>

    <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight leading-[1.1] mb-6 max-w-3xl mx-auto text-white">
      Er din hjemmeside synlig for AI?
    </h1>

    <p class="text-lg md:text-xl text-white/60 mb-10 max-w-2xl mx-auto leading-relaxed">
      ChatGPT, Perplexity og Google AI svarer paa millioner af soegninger dagligt.
      Vi viser dig om de anbefaler dig, dine konkurrenter, eller slet ingen.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="#contact" class="bg-accent text-brand px-8 py-4 font-bold text-lg hover:bg-accent-light transition-colors">
        Bestil rapport — 2.495 kr
      </a>
      <a href="#how-it-works" class="border border-white/20 text-white/80 px-8 py-4 font-semibold text-lg hover:border-white/50 hover:text-white transition-colors">
        Se hvordan det virker
      </a>
    </div>

    <!-- Trust indicators -->
    <div class="mt-16 flex flex-wrap justify-center gap-8 md:gap-12 text-sm text-white/40">
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        <span>5 AI-platforme testet</span>
      </div>
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        <span>10 tekniske tests</span>
      </div>
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"/></svg>
        <span>Handlingsbar rapport</span>
      </div>
    </div>
  </div>
</section>

          <svg viewBox="0 0 32 32" class="w-7 h-7" xmlns="http://www.w3.org/2000/svg">
            <circle cx="16" cy="16" r="16" fill="#f2e5d0"/>
            <circle cx="16" cy="16" r="12.5" fill="none" stroke="#9f6a24" stroke-width="1.2"/>
            <circle cx="16" cy="16" r="8" fill="none" stroke="#9f6a24" stroke-width="1" opacity="0.6"/>

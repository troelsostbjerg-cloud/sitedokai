---
const snapshotCards = [
  {
    label: 'AI-status',
    value: '67 / 100',
    body: 'Et samlet billede af hvor virksomheden står, før teamet læser den fulde forklaring.',
  },
  {
    label: 'Største hul',
    value: 'Kategori-søgninger',
    body: 'De brede søgninger går stadig oftere til konkurrenter end til jer.',
  },
  {
    label: 'Første fokus',
    value: '3 næste skridt',
    body: 'Leverancen ender ikke i analyse alene, men i konkrete prioriteringer for teamet.',
  },
];

const flowSteps = [
  'Kort status først, så ledelse og marketing hurtigt kan aflæse situationen.',
  'Tabte søgninger og konkurrentbillede før anbefalinger, så behovet bliver tydeligt.',
  'Tre næste skridt med sandsynlig effekt, så det er let at vælge hvor man starter.',
];
---

<section class="bg-[#f6f1e8] border-y border-[#e6ddd1]">
  <div class="max-w-6xl mx-auto px-6 py-20 md:py-28">
    <div class="grid grid-cols-1 lg:grid-cols-[0.95fr_1.05fr] gap-10 items-start">
      <div class="max-w-2xl">
        <p class="text-sm text-accent font-semibold uppercase tracking-[0.18em] mb-4">Client Room demo</p>
        <h2 class="font-display text-3xl md:text-5xl font-extrabold text-brand leading-tight">
          Se hvordan en audit bliver til et overblik man faktisk kan handle på
        </h2>
        <p class="mt-5 text-brand/68 text-lg leading-relaxed">
          Client Roomet er bygget til at gøre én ting klart: hvor AI allerede påvirker kundens shortlist, og hvad der
          mest sandsynligt flytter situationen. Det er mindre pitch og mere beslutningsgrundlag.
        </p>

        <div class="mt-8 space-y-3">
          {flowSteps.map((step, index) => (
            <div class="flex items-start gap-3 rounded-2xl border border-[#e2d8ca] bg-white/80 px-4 py-4 shadow-[0_10px_30px_rgba(31,42,51,0.05)]">
              <span class="mt-0.5 inline-flex h-7 w-7 items-center justify-center rounded-full border border-[#d9ccb9] bg-[#faf6ef] text-sm font-bold text-brand">{index + 1}</span>
              <p class="text-sm text-brand/72 leading-relaxed">{step}</p>
            </div>
          ))}
        </div>

        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <a href="/eksempel" class="inline-flex items-center justify-center rounded-md bg-brand px-6 py-3.5 text-base font-bold text-white transition-colors hover:bg-brand-light">
            Se hele demoen
          </a>
          <a href="/om" class="inline-flex items-center justify-center rounded-md border border-[#d8ccb9] bg-white px-6 py-3.5 text-base font-bold text-brand/78 transition-colors hover:text-brand hover:bg-[#faf7f2]">
            Læs om metoden
          </a>
        </div>
      </div>

      <div class="rounded-[2rem] border border-[#ddd2c4] bg-white p-5 md:p-6 shadow-[0_28px_70px_rgba(31,42,51,0.08)]">
        <div class="rounded-[1.5rem] border border-[#ece3d7] bg-[#fcfaf6] p-5 md:p-6">
          <div class="flex items-center justify-between gap-4 border-b border-[#ebe1d4] pb-4">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand/45">Fiktivt eksempel</p>
              <h3 class="mt-2 font-display text-2xl font-bold text-brand">EvigtUnivers</h3>
            </div>
            <div class="rounded-full border border-[#deceb8] bg-[#f5ede0] px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em] text-brand/55">
              Client Room
            </div>
          </div>

          <div class="mt-5 overflow-hidden rounded-[1.35rem] border border-[#e6ddd1] bg-[#f3ece2] shadow-[0_16px_40px_rgba(31,42,51,0.08)]">
            <div class="flex items-center justify-between gap-4 border-b border-[#e2d7c8] px-4 py-3 text-[11px] font-semibold uppercase tracking-[0.16em] text-brand/45">
              <span>Hjemmesidevideo</span>
              <span>Muted autoplay</span>
            </div>

            <video
              class="block w-full aspect-[16/10] object-cover bg-[#e8dfd2]"
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
              poster="/client-room-tour-poster.png"
            >
              <source src="/client-room-tour.mp4" type="video/mp4" />
            </video>
          </div>

          <div class="mt-5 grid grid-cols-1 md:grid-cols-3 gap-4">
            {snapshotCards.map((card) => (
              <article class="rounded-2xl border border-[#e8dece] bg-white p-4">
                <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-brand/45">{card.label}</p>
                <p class="mt-3 font-display text-2xl font-bold text-brand">{card.value}</p>
                <p class="mt-3 text-sm leading-relaxed text-brand/68">{card.body}</p>
              </article>
            ))}
          </div>

          <div class="mt-5 rounded-2xl border border-[#e6ddd1] bg-white p-5">
            <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-brand/45">Hvad man ser først</p>
            <div class="mt-4 space-y-3">
              <div class="flex items-center justify-between gap-4 rounded-xl bg-[#faf6ef] px-4 py-3">
                <span class="text-sm font-semibold text-brand">Tabte kategori-søgninger</span>
                <span class="text-xs font-semibold uppercase tracking-[0.14em] text-[#a25b2a]">Kræver fokus</span>
              </div>
              <div class="flex items-center justify-between gap-4 rounded-xl bg-[#faf6ef] px-4 py-3">
                <span class="text-sm font-semibold text-brand">Konkurrenter med stærkere beviser</span>
                <span class="text-xs font-semibold uppercase tracking-[0.14em] text-[#a25b2a]">Forklares tydeligt</span>
              </div>
              <div class="flex items-center justify-between gap-4 rounded-xl bg-[#faf6ef] px-4 py-3">
                <span class="text-sm font-semibold text-brand">Tre prioriterede næste skridt</span>
                <span class="text-xs font-semibold uppercase tracking-[0.14em] text-[#8a6a34]">Klar til brug</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

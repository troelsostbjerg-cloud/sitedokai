---
interface MetricCard {
  label: string;
  value: string;
  description: string;
  tone?: 'default' | 'accent' | 'amber';
}

interface ActionCard {
  title: string;
  effort: string;
  confidence: string;
  owner: string;
  why: string;
  summary: string;
  impact: string;
}

interface ScenarioCard {
  title: string;
  effort: string;
  confidence: string;
  summary: string;
  aiLift: string;
  coverageLift: string;
  interestLift: string;
  selected?: boolean;
}

interface QueryCard {
  state: string;
  query: string;
  description: string;
  nextMove: string;
  tone: 'critical' | 'watch' | 'stable';
}

interface CompetitorRow {
  name: string;
  visibility: string;
  note: string;
  isClient?: boolean;
}

interface ProofCard {
  title: string;
  body: string;
}

interface PreviewHighlight {
  title: string;
  body: string;
}

interface Props {
  variant?: 'compact' | 'full';
  showExportLink?: boolean;
}

const { variant = 'compact', showExportLink = variant === 'full' } = Astro.props;
const isCompact = variant === 'compact';

const metrics: MetricCard[] = [
  {
    label: 'Hvor I står nu',
    value: '32/100',
    description: 'I bliver primært fundet, når nogen allerede kender jeres navn.',
    tone: 'accent',
  },
  {
    label: 'Hvad der flytter mest',
    value: 'Tydelige ydelsessider',
    description: 'Især sider om catering og frokostordning vil gøre jer lettere at vælge.',
  },
  {
    label: 'Mulig effekt',
    value: '+18% til +32%',
    description: 'Det er vores bedste bud på, hvor meget mere relevant interesse I kan skabe først.',
    tone: 'amber',
  },
];

const blockers = [
  'AI forstår ikke tydeligt nok, hvad I leverer, når søgningen ikke nævner jeres navn.',
  'Konkurrenter har flere friske signaler på troværdighed og bliver derfor valgt oftere.',
  'Jeres vigtigste sider gør det for svært at forstå forskellen på jer og alternativerne.',
];

const actions: ActionCard[] = [
  {
    title: 'Lav to stærke sider om catering og frokostordning',
    effort: 'Mellem',
    confidence: 'Høj sikkerhed',
    owner: 'Jer sammen med tekst/marketing',
    why: 'Det er her I mister flest brede søgninger i dag.',
    summary: 'Siderne skal svare klart på hvem I hjælper, hvad I leverer, og hvorfor kunder skal vælge jer.',
    impact: 'Mest sandsynligt +14%',
  },
  {
    title: 'Gør beviser på kvalitet tydeligere',
    effort: 'Lav',
    confidence: 'Godt bud',
    owner: 'Jer',
    why: 'AI løfter oftere virksomheder frem, når anmeldelser, cases og fakta er lette at finde.',
    summary: 'Saml anmeldelser, leveringsområder, priser og svar på typiske spørgsmål på de vigtigste sider.',
    impact: 'Mest sandsynligt +9%',
  },
  {
    title: 'Opdatér jeres profiler uden for websitet',
    effort: 'Lav',
    confidence: 'Godt bud',
    owner: 'Jer',
    why: 'Flere modeller bruger data fra profiler og omtaler uden for jeres eget website.',
    summary: 'Sørg for samme beskrivelse, billeder og kontaktoplysninger på tværs af Google og brancheprofiler.',
    impact: 'Mest sandsynligt +6%',
  },
];

const scenarios: ScenarioCard[] = [
  {
    title: 'Tydelige servicesider',
    effort: 'Mellem',
    confidence: 'Høj sikkerhed',
    summary: 'Gør det nemt for både kunder og AI at forstå jeres vigtigste ydelser.',
    aiLift: '+11 point',
    coverageLift: '+16%',
    interestLift: '+14%',
    selected: true,
  },
  {
    title: 'Mere troværdighed på siden',
    effort: 'Lav',
    confidence: 'Godt bud',
    summary: 'Læg anmeldelser, cases og konkrete fakta tættere på beslutningen.',
    aiLift: '+6 point',
    coverageLift: '+9%',
    interestLift: '+9%',
    selected: true,
  },
  {
    title: 'Opdaterede profiler og virksomhedsdata',
    effort: 'Lav',
    confidence: 'Godt bud',
    summary: 'Fjern gamle oplysninger og gør jeres vigtigste profiler ens.',
    aiLift: '+4 point',
    coverageLift: '+6%',
    interestLift: '+5%',
  },
];

const queries: QueryCard[] = [
  {
    state: 'Stort hul',
    query: 'catering firma københavn',
    description: 'Konkurrenter bliver nævnt, mens I næsten ikke dukker op.',
    nextMove: 'Byg en side der tydeligt svarer på denne søgning.',
    tone: 'critical',
  },
  {
    state: 'Ustabil',
    query: 'frokostordning virksomhed københavn',
    description: 'I bliver nævnt enkelte steder, men ikke stabilt nok til at blive valgt.',
    nextMove: 'Skærp sideindhold og gør priser/ydelser tydelige.',
    tone: 'watch',
  },
  {
    state: 'Godt udgangspunkt',
    query: 'nordisk køkken catering',
    description: 'Når folk søger direkte på jer, ser det langt bedre ud.',
    nextMove: 'Brug det som model for de brede søgninger.',
    tone: 'stable',
  },
];

const competitors: CompetitorRow[] = [
  {
    name: 'Nordisk Køkken',
    visibility: '3 ud af 10 brede søgninger',
    note: 'Stærk på eget navn, svag på de brede valg-søgninger.',
    isClient: true,
  },
  {
    name: 'MadMarkedet',
    visibility: '7 ud af 10 brede søgninger',
    note: 'Vinder på tydelige ydelsessider og flere beviser på troværdighed.',
  },
  {
    name: 'FrokostHuset',
    visibility: '5 ud af 10 brede søgninger',
    note: 'Står bedre fordi deres sider er mere konkrete og lettere at forstå.',
  },
];

const proofPoints: ProofCard[] = [
  {
    title: 'Vi ser at konkurrenter bliver nævnt først',
    body: 'På de vigtigste brede søgninger går anbefalingerne oftere til konkurrenterne end til jer.',
  },
  {
    title: 'Jeres egne sider er for brede i sproget',
    body: 'Det er uklart nok, hvilke ydelser I tilbyder, hvem de passer til, og hvorfor de skal vælges.',
  },
  {
    title: 'Der mangler tydelige tegn på kvalitet',
    body: 'Anmeldelser, cases, levering og praktiske oplysninger er ikke samlet stærkt nok omkring beslutningen.',
  },
];

const previewHighlights: PreviewHighlight[] = [
  {
    title: 'Status på få sekunder',
    body: 'Få den korte version først, så det hurtigt står klart hvor virksomheden står nu.',
  },
  {
    title: 'Tabte søgninger først',
    body: 'Se hvilke brede søgninger der går til konkurrenter, før anbefalingerne kommer på bordet.',
  },
  {
    title: 'Tre næste skridt',
    body: 'Gør det tydeligt hvad teamet starter med, og hvorfor det er prioriteret.',
  },
];
---

<section id={isCompact ? 'demo' : undefined} class:list={['client-room-section', isCompact && 'client-room-section-compact']}>
  {isCompact ? (
    <>
      <div class="section-intro">
        <p class="section-eyebrow">Demo</p>
        <h2>Se en guidet tur i Client Room</h2>
        <p>
          Videoen viser den korte version: status, tabte søgninger, næste skridt og dokumentation
          i det format, kunder faktisk får efter en audit.
        </p>
      </div>

      <div class="guided-shell">
        <div class="room-browser">
          <div class="browser-dots" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </div>
          <div class="browser-label">Client Room · Nordisk Køkken</div>
          <div class="browser-state">Video preview</div>
        </div>

        <div class="guided-stage">
          <div class="guided-video-frame">
            <video
              class="guided-video"
              data-client-room-video
              data-src="/client-room-tour.mp4"
              poster="/client-room-tour-poster.png"
              muted
              loop
              playsinline
              preload="none"
              aria-label="Guidet preview af Client Room"
            ></video>

          </div>
        </div>
      </div>

      <div class="guided-highlights">
        {previewHighlights.map((item) => (
          <article class="guided-highlight-card">
            <span class="metric-label">{item.title}</span>
            <p>{item.body}</p>
          </article>
        ))}
      </div>

      <div class="preview-actions">
        <a href="/eksempel" class="preview-primary">Åbn hele Client Room-demoen</a>
        <a href="/kontakt" class="preview-secondary">Bestil din audit</a>
      </div>
    </>
  ) : (
    <div class="room-shell">
      <div class="room-browser">
        <div class="browser-dots" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </div>
        <div class="browser-label">Client Room · Nordisk Køkken</div>
        <div class="browser-state">Demo</div>
      </div>

      <div class="room-body">
        <section class="room-hero">
          <div>
            <div class="room-eyebrow">Jeres overblik</div>
            <h3>Nordisk Køkken</h3>
            <p class="room-lead room-lead-strong">
              I bliver fundet, når folk allerede kender jer, men I går glip af kunder når de søger bredt efter catering og frokostordning.
            </p>
            <p class="room-lead">
              Det største løft ligger i tydeligere ydelsessider, stærkere tegn på kvalitet og mere ens oplysninger på tværs af jeres profiler.
            </p>

            <div class="verdict-strip">
              <div class="verdict-item">
                <span>Hvor sikre vi er</span>
                <strong>Høj sikkerhed</strong>
              </div>
              <div class="verdict-item">
                <span>Hvor bredt I bliver nævnt</span>
                <strong>58%</strong>
              </div>
              <div class="verdict-item">
                <span>Start her</span>
                <strong>Servicesiderne</strong>
              </div>
            </div>
          </div>

          <aside class="meta-box">
            <div>
              <span>Senest opdateret</span>
              <strong>5. april 2026</strong>
            </div>
            <div>
              <span>Visning</span>
              <strong>Interaktiv gennemgang</strong>
            </div>
            <div>
              <span>Format</span>
              <strong>Interaktiv side + eksport</strong>
            </div>
            {showExportLink && (
              <a class="meta-link" href="/demo-rapport.html">Se eksporteksemplet</a>
            )}
          </aside>
        </section>

        <section class="metric-grid">
          {metrics.map((metric) => (
            <article class:list={['metric-card', metric.tone && `metric-${metric.tone}`]}>
              <span class="metric-label">{metric.label}</span>
              <strong>{metric.value}</strong>
              <p>{metric.description}</p>
            </article>
          ))}
        </section>

        <section class="room-panel">
          <div class="panel-head">
            <div>
              <p class="room-eyebrow">Kort fortalt</p>
              <h4>Det vigtigste lige nu</h4>
            </div>
            <p>Her er den korte version, så ledelsen hurtigt kan se hvor det gør mest ondt.</p>
          </div>

          <div class="bullet-grid">
            {blockers.map((blocker) => (
              <article class="bullet-card">
                <span class="metric-label">Det holder jer tilbage</span>
                <strong>{blocker}</strong>
              </article>
            ))}
          </div>
        </section>

        <section class="room-panel">
          <div class="panel-head">
            <div>
              <p class="room-eyebrow">Næste 30 dage</p>
              <h4>Det her skal I gøre først</h4>
            </div>
            <p>Tre prioriterede bevægelser, så det er tydeligt hvad teamet skal starte med.</p>
          </div>

          <div class="actions-grid">
            {actions.map((action, index) => (
              <article class="action-card">
                <div class="action-step">{index + 1}</div>
                <div class="action-copy">
                  <div class="action-meta-top">
                    <span class="pill">Indsats {action.effort}</span>
                    <span class="mini-pill">{action.confidence}</span>
                  </div>
                  <h5>{action.title}</h5>
                  <p class="action-why">{action.why}</p>
                  <p>{action.summary}</p>
                  <div class="action-meta-bottom">
                    <span>Hvem: {action.owner}</span>
                    <span>{action.impact}</span>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="room-panel">
          <div class="panel-head">
            <div>
              <p class="room-eyebrow">Hvis I gør det her</p>
              <h4>Sådan kan det flytte sig</h4>
            </div>
            <p>Eksemplet her viser den interaktive del i et roligt, ledelsesvenligt format.</p>
          </div>

          <div class="forecast-layout">
            <div class="scenario-grid">
              {scenarios.map((scenario) => (
                <article class:list={['scenario-card', scenario.selected && 'scenario-card-active']}>
                  <div class="scenario-top">
                    <span class="pill">Indsats {scenario.effort}</span>
                    <span class="mini-pill">{scenario.confidence}</span>
                  </div>
                  <h5>{scenario.title}</h5>
                  <p>{scenario.summary}</p>
                  <div class="scenario-meta">
                    <span>Synlighed {scenario.aiLift}</span>
                    <span>Bredde {scenario.coverageLift}</span>
                    <span>Interesse {scenario.interestLift}</span>
                  </div>
                </article>
              ))}
            </div>

            <div class="forecast-card">
              <div class="forecast-kpis">
                <div>
                  <span>Synlighed i AI-svar</span>
                  <strong>32 → 49</strong>
                </div>
                <div>
                  <span>Hvor bredt I bliver nævnt</span>
                  <strong>58% → 73%</strong>
                </div>
                <div>
                  <span>Mulig ekstra interesse</span>
                  <strong>+23%</strong>
                </div>
              </div>

              <div class="forecast-bars">
                <div class="bar-row">
                  <div class="bar-label">Synlighed i AI-svar</div>
                  <div class="bar-track">
                    <div class="bar-current" style="width: 32%"></div>
                    <div class="bar-project" style="width: 49%"></div>
                    <div class="bar-target" style="left: 74%"></div>
                  </div>
                </div>
                <div class="bar-row">
                  <div class="bar-label">Hvor bredt I bliver nævnt</div>
                  <div class="bar-track">
                    <div class="bar-current" style="width: 58%"></div>
                    <div class="bar-project" style="width: 73%"></div>
                    <div class="bar-target" style="left: 84%"></div>
                  </div>
                </div>
              </div>

              <p class="forecast-note">
                Tallene viser retning og størrelsesorden. De er lavet for at støtte beslutninger, ikke for at love et bestemt resultat.
              </p>
            </div>
          </div>
        </section>

        <section class="room-panel">
          <div class="panel-head">
            <div>
              <p class="room-eyebrow">Vigtige søgninger</p>
              <h4>Her går I glip af kunder</h4>
            </div>
            <p>Det her er de søgninger, vi ville reagere på først.</p>
          </div>

          <div class="query-grid">
            {queries.map((item) => (
              <article class:list={['query-card', `query-${item.tone}`]}>
                <div class="query-top">
                  <span class="pill">{item.state}</span>
                </div>
                <h5>{item.query}</h5>
                <p>{item.description}</p>
                <div class="query-note">{item.nextMove}</div>
              </article>
            ))}
          </div>
        </section>

        <section class="room-panel">
          <div class="panel-head">
            <div>
              <p class="room-eyebrow">Konkurrenterne</p>
              <h4>Sådan står I lige nu</h4>
            </div>
            <p>
              I står ikke dårligt, fordi I er ukendte. I står efter konkurrenterne, fordi deres vigtigste sider er lettere at forstå og lettere at stole på.
            </p>
          </div>

          <div class="competitor-layout">
            <article class="competitor-summary">
              <span class="metric-label">Kort læsning</span>
              <strong>MadMarkedet bliver oftere valgt på de brede søgninger</strong>
              <p>
                Når nogen spørger bredt efter catering eller frokostordning i København, er konkurrenterne tydeligere i AI-svarene end jer.
              </p>
            </article>

            <div class="competitor-list">
              {competitors.map((row) => (
                <article class:list={['competitor-row', row.isClient && 'competitor-row-client']}>
                  <div>
                    <strong>{row.name}</strong>
                    <p>{row.note}</p>
                  </div>
                  <span>{row.visibility}</span>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section class="room-panel">
          <div class="panel-head">
            <div>
              <p class="room-eyebrow">Dokumentation</p>
              <h4>Det bygger vi vurderingen på</h4>
            </div>
            <p>Vi viser kun det nederste lag i kort form, så det er til at forstå uden at drukne i detaljer.</p>
          </div>

          <div class="proof-grid">
            {proofPoints.map((proof) => (
              <article class="proof-card">
                <strong>{proof.title}</strong>
                <p>{proof.body}</p>
              </article>
            ))}
          </div>
        </section>

        {showExportLink && (
          <section class="export-strip">
            <div>
              <span>Eksport</span>
              <strong>Client Room er hovedoplevelsen. Eksporten er kun til deling internt.</strong>
            </div>
            <a href="/demo-rapport.html">Åbn eksporteksemplet</a>
          </section>
        )}
      </div>
    </div>
  )}
</section>

<style>
  .client-room-section {
    background: #020617;
    color: #e5eef9;
  }

  .client-room-section-compact {
    padding: 5rem 1.5rem 6rem;
  }

  .section-intro {
    max-width: 52rem;
    margin: 0 auto 2rem;
  }

  .section-eyebrow,
  .room-eyebrow {
    margin: 0 0 0.75rem;
    color: #22d3ee;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .section-intro h2 {
    margin: 0 0 1rem;
    font-family: "Bricolage Grotesque", system-ui, sans-serif;
    font-size: clamp(2.1rem, 3.4vw, 3.2rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.02;
  }

  .section-intro p {
    margin: 0;
    max-width: 44rem;
    color: rgba(226, 232, 240, 0.72);
    font-size: 1.03rem;
    line-height: 1.75;
  }

  .room-shell {
    position: relative;
    max-width: 78rem;
    margin: 0 auto;
    overflow: hidden;
    border: 1px solid rgba(34, 211, 238, 0.18);
    border-radius: 2rem;
    background:
      radial-gradient(circle at top left, rgba(34, 211, 238, 0.12), transparent 28rem),
      radial-gradient(circle at right 20%, rgba(251, 191, 36, 0.1), transparent 24rem),
      linear-gradient(180deg, #07111f 0%, #050b16 100%);
    box-shadow: 0 40px 120px rgba(2, 8, 23, 0.55);
  }

  .room-shell::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle at 1px 1px, rgba(148, 163, 184, 0.12) 1px, transparent 0);
    background-size: 36px 36px;
    opacity: 0.24;
    pointer-events: none;
  }

  .room-shell-compact {
    max-height: 72rem;
  }

  .guided-shell,
  .guided-highlights {
    max-width: 78rem;
    margin-inline: auto;
  }

  .guided-shell {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(34, 211, 238, 0.18);
    border-radius: 2rem;
    background:
      radial-gradient(circle at top left, rgba(34, 211, 238, 0.12), transparent 28rem),
      radial-gradient(circle at right 20%, rgba(251, 191, 36, 0.1), transparent 24rem),
      linear-gradient(180deg, #07111f 0%, #050b16 100%);
    box-shadow: 0 40px 120px rgba(2, 8, 23, 0.55);
  }

  .guided-shell::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle at 1px 1px, rgba(148, 163, 184, 0.12) 1px, transparent 0);
    background-size: 36px 36px;
    opacity: 0.24;
    pointer-events: none;
  }

  .guided-stage {
    position: relative;
    z-index: 1;
    padding: 1rem;
  }

  .guided-video-frame {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.6rem;
    background: linear-gradient(180deg, #07111f 0%, #040814 100%);
    aspect-ratio: 16 / 9;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
  }

  .guided-video {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    background: #020617;
  }

  .guided-highlights {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.25rem;
  }

  .guided-highlight-card {
    padding: 1.15rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.25rem;
    background: rgba(8, 17, 31, 0.82);
    box-shadow: 0 30px 80px rgba(2, 8, 23, 0.32);
  }

  .guided-highlight-card p {
    margin: 0.7rem 0 0;
    color: rgba(226, 232, 240, 0.72);
    font-size: 0.96rem;
    line-height: 1.65;
  }

  .room-browser,
  .room-body {
    position: relative;
    z-index: 1;
  }

  .room-browser {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(4, 10, 22, 0.78);
    backdrop-filter: blur(18px);
  }

  .browser-dots {
    display: flex;
    gap: 0.45rem;
  }

  .browser-dots span {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 999px;
    background: rgba(226, 232, 240, 0.22);
  }

  .browser-dots span:first-child {
    background: rgba(248, 113, 113, 0.85);
  }

  .browser-dots span:nth-child(2) {
    background: rgba(251, 191, 36, 0.85);
  }

  .browser-dots span:last-child {
    background: rgba(16, 185, 129, 0.85);
  }

  .browser-label,
  .browser-state {
    color: rgba(226, 232, 240, 0.75);
    font-size: 0.86rem;
    font-weight: 600;
  }

  .browser-state {
    justify-self: end;
    color: #67e8f9;
  }

  .room-body {
    display: grid;
    gap: 1.25rem;
    padding: 1.25rem;
  }

  .room-hero,
  .room-panel,

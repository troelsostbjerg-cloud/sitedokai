---
---
<div class="hero-anim mx-auto max-w-4xl mt-12" aria-hidden="true">
  <div class="ha-browser">
    <div class="ha-chrome">
      <div class="ha-dots"><span></span><span></span><span></span></div>
      <div class="ha-url"><span class="ha-lock">●</span> nordiskkokken.dk</div>
    </div>
    <div class="ha-page">
      <div class="ha-scanline" id="haScanline"></div>
      <div class="ha-site">
        <div class="ha-site-nav">
          <div class="ha-site-logo">
            <div class="ha-logo-dot"></div>
            <span class="ha-logo-text">Nordisk Køkken</span>
          </div>
          <div class="ha-site-links">
            <span>Menu</span>
            <span>Catering</span>
            <span>Selskaber</span>
            <span class="ha-nav-cta">Book bord</span>
          </div>
        </div>

        <div class="ha-site-content">
          <div class="ha-site-hero">
            <div class="ha-site-title">Frokostordning og catering i København</div>
            <div class="ha-site-subtitle">Nordisk frokost, mødeforplejning og events for virksomheder. Levering alle hverdage.</div>
            <div class="ha-site-btns">
              <span class="ha-btn-primary">Se cateringpakker</span>
              <span class="ha-btn-ghost">Læs anmeldelser</span>
            </div>
          </div>

          <div class="ha-site-meta">
            <div class="ha-meta-card">
              <div class="ha-meta-label">Lokation</div>
              <div class="ha-meta-value">København K</div>
            </div>
            <div class="ha-meta-card">
              <div class="ha-meta-label">Åbningstid</div>
              <div class="ha-meta-value">Man-fre 08-17</div>
            </div>
            <div class="ha-meta-card ha-meta-card-warn">
              <div class="ha-meta-label">Schema</div>
              <div class="ha-meta-value">Mangler</div>
            </div>
          </div>

          <div class="ha-site-cards">
            <div class="ha-card">
              <div class="ha-card-title">AI-fund</div>
              <div class="ha-card-text">ChatGPT nævner ikke siden på søgninger om frokostordning.</div>
            </div>
            <div class="ha-card">
              <div class="ha-card-title">Teknisk fund</div>
              <div class="ha-card-text">Core Web Vitals og struktur gør siden sværere at forstå.</div>
            </div>
            <div class="ha-card">
              <div class="ha-card-title">Prioritet</div>
              <div class="ha-card-text">Opdatér schema, landingssider og virksomhedsdata først.</div>
            </div>
          </div>
        </div>
      </div>

      <div class="ha-scan-overlay" id="haScanOverlay"></div>
    </div>
  </div>

  <div class="ha-panel" id="haPanel">
    <div class="ha-panel-left">
      <div class="ha-platforms">
        <div class="ha-result" data-status="missing" data-delay="900" data-label="Ikke nævnt">
          <div class="ha-r-icon ha-chatgpt">C</div>
          <span class="ha-r-name">ChatGPT</span>
          <span class="ha-r-badge"></span>
        </div>
        <div class="ha-result" data-status="warning" data-delay="1400" data-label="Begrænset">
          <div class="ha-r-icon ha-claude">Cl</div>
          <span class="ha-r-name">Claude</span>
          <span class="ha-r-badge"></span>
        </div>
        <div class="ha-result" data-status="missing" data-delay="1900" data-label="Konkurrent først">
          <div class="ha-r-icon ha-google">G</div>
          <span class="ha-r-name">Google AI</span>
          <span class="ha-r-badge"></span>
        </div>
        <div class="ha-result" data-status="warning" data-delay="2400" data-label="Forældet info">
          <div class="ha-r-icon ha-gemini">Ge</div>
          <span class="ha-r-name">Gemini</span>
          <span class="ha-r-badge"></span>
        </div>
      </div>
    </div>
    <div class="ha-panel-right">
      <div class="ha-score-ring">
        <svg viewBox="0 0 80 80" class="ha-ring-svg">
          <circle cx="40" cy="40" r="34" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="5"/>
          <circle cx="40" cy="40" r="34" fill="none" stroke="url(#scoreGrad)" stroke-width="5" stroke-linecap="round" stroke-dasharray="213.6" stroke-dashoffset="213.6" transform="rotate(-90 40 40)" id="haRingCircle"/>
          <defs>
            <linearGradient id="scoreGrad" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="#ef4444"/>
              <stop offset="100%" stop-color="#fbbf24"/>
            </linearGradient>
          </defs>
        </svg>
        <div class="ha-score-value" id="haScoreNum">0</div>
      </div>
      <div class="ha-score-meta">
        <span class="ha-score-label">AI-synlighed</span>
        <span class="ha-score-verdict" id="haVerdict"></span>
      </div>
    </div>
  </div>
</div>

<style>
  .hero-anim {
    position: relative;
  }

  .ha-browser {
    background: rgba(2, 6, 23, 0.88);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 30px 80px -24px rgba(0, 0, 0, 0.55), 0 0 0 1px rgba(255, 255, 255, 0.03), 0 0 60px -20px rgba(6, 182, 212, 0.08);
  }

  .ha-chrome {
    height: 38px;
    background: rgba(15, 23, 42, 0.9);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    display: flex;
    align-items: center;
    padding: 0 14px;
    gap: 8px;
  }

  .ha-dots {
    display: flex;
    gap: 6px;
  }

  .ha-dots span {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    display: block;
  }

  .ha-dots span:nth-child(1) { background: rgba(239, 68, 68, 0.5); }
  .ha-dots span:nth-child(2) { background: rgba(251, 191, 36, 0.5); }
  .ha-dots span:nth-child(3) { background: rgba(34, 197, 94, 0.5); }

  .ha-url {
    flex: 1;
    height: 22px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 6px;
    margin-left: 8px;
    display: flex;
    align-items: center;
    padding: 0 10px;
    font-size: 11px;
    color: rgba(255, 255, 255, 0.34);
    font-family: 'Inter', system-ui, sans-serif;
  }

  .ha-lock {
    color: rgba(34, 197, 94, 0.7);
    font-size: 7px;
    margin-right: 6px;
  }

  .ha-page {
    padding: 18px 20px 20px;
    position: relative;
    min-height: 260px;
    overflow: hidden;
  }

  .ha-site {
    font-family: 'Inter', system-ui, sans-serif;
    position: relative;
    z-index: 1;
  }

  .ha-site-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    margin-bottom: 16px;
  }

  .ha-site-logo {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .ha-logo-dot {
    width: 10px;
    height: 10px;
    border-radius: 3px;
    background: rgba(251, 191, 36, 0.8);
  }

  .ha-logo-text {
    font-size: 10px;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.7);
    letter-spacing: 0.3px;
  }

  .ha-site-links {
    display: flex;
    gap: 12px;
    font-size: 8px;
    color: rgba(255, 255, 255, 0.32);
    font-weight: 500;
  }

  .ha-nav-cta {
    background: rgba(251, 191, 36, 0.16);
    color: rgba(251, 191, 36, 0.9);
    padding: 2px 8px;
    border-radius: 3px;
  }

  .ha-site-content {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 14px;
    align-items: start;
  }

  .ha-site-hero {
    padding: 8px 0 0;
  }

  .ha-site-title {
    font-size: 16px;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.3;
    margin-bottom: 8px;
    max-width: 280px;
  }

  .ha-site-subtitle {
    font-size: 9px;
    color: rgba(255, 255, 255, 0.44);
    line-height: 1.6;
    max-width: 290px;
    margin-bottom: 12px;
  }

  .ha-site-btns {
    display: flex;
    gap: 8px;
  }

  .ha-btn-primary,
  .ha-btn-ghost {
    font-size: 7px;
    border-radius: 5px;
    padding: 5px 10px;
  }

  .ha-btn-primary {
    font-weight: 700;
    background: rgba(251, 191, 36, 0.22);
    color: rgba(251, 191, 36, 0.95);
  }

  .ha-btn-ghost {
    font-weight: 500;
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.42);
  }

  .ha-site-meta {
    display: grid;
    gap: 8px;
  }

  .ha-meta-card {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 10px;
    padding: 10px;
  }

  .ha-meta-card-warn {
    border-color: rgba(239, 68, 68, 0.15);
    background: rgba(239, 68, 68, 0.06);
  }

  .ha-meta-label {
    font-size: 7px;
    color: rgba(255, 255, 255, 0.38);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 4px;
  }

  .ha-meta-value {
    font-size: 10px;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.8);
  }

  .ha-site-cards {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 8px;
    margin-top: 4px;
  }

  .ha-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 10px;
    padding: 10px;
  }

  .ha-card-title {
    font-size: 8px;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 4px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .ha-card-text {
    font-size: 7px;
    color: rgba(255, 255, 255, 0.38);
    line-height: 1.5;
  }

  .ha-scanline {
    position: absolute;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent 0%, rgba(6, 182, 212, 0.4) 15%, rgba(6, 182, 212, 1) 50%, rgba(6, 182, 212, 0.4) 85%, transparent 100%);
    box-shadow: 0 0 16px 4px rgba(6, 182, 212, 0.2), 0 0 40px 8px rgba(6, 182, 212, 0.06);
    top: 0;
    opacity: 0;
    z-index: 10;
    pointer-events: none;
    transition: top 3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s;
  }

  .ha-scanline::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    height: 70px;
    background: linear-gradient(180deg, rgba(6, 182, 212, 0.05) 0%, transparent 100%);
  }

  .ha-scan-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(6, 182, 212, 0.03) 0%, transparent 48%);
    opacity: 0;
    transition: opacity 0.6s;
    pointer-events: none;
    z-index: 2;
  }

  .ha-scan-overlay.active {
    opacity: 1;
  }

  .ha-panel {
    margin-top: 14px;
    display: flex;
    gap: 12px;
    align-items: stretch;
    opacity: 0;
    transform: translateY(8px);
    transition: all 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .ha-panel.show {
    opacity: 1;
    transform: translateY(0);
  }

  .ha-panel-left,
  .ha-panel-right {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px;
  }

  .ha-panel-left {
    flex: 1;
    padding: 12px;
  }

  .ha-platforms {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }

  .ha-result {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 10px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 8px;
    opacity: 0;
    transform: scale(0.95);
    transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .ha-result.show {
    opacity: 1;
    transform: scale(1);
  }

  .ha-result.is-found {
    border-color: rgba(34, 197, 94, 0.25);
    background: rgba(34, 197, 94, 0.05);
  }

  .ha-result.is-missing {
    border-color: rgba(239, 68, 68, 0.2);
    background: rgba(239, 68, 68, 0.04);
  }

  .ha-result.is-warning {
    border-color: rgba(251, 191, 36, 0.24);
    background: rgba(251, 191, 36, 0.05);
  }

  .ha-r-icon {
    width: 24px;
    height: 24px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 9px;
    font-weight: 700;
    font-family: 'Inter', system-ui, sans-serif;
  }

  .ha-chatgpt { background: rgba(16, 163, 127, 0.15); color: #10a37f; }
  .ha-claude  { background: rgba(217, 119, 62, 0.15); color: #d9773e; }
  .ha-google  { background: rgba(66, 133, 244, 0.15); color: #4285f4; }
  .ha-gemini  { background: rgba(138, 100, 255, 0.15); color: #8a64ff; }

  .ha-r-name {
    font-size: 11px;
    color: rgba(255, 255, 255, 0.48);
    font-weight: 500;
    font-family: 'Inter', system-ui, sans-serif;
    flex: 1;
  }

  .ha-r-badge {
    font-size: 10px;
    font-weight: 700;
    font-family: 'Inter', system-ui, sans-serif;
    text-align: right;
  }

  .ha-r-badge.ok { color: #4ade80; }
  .ha-r-badge.no { color: #f87171; }
  .ha-r-badge.warn { color: #fbbf24; }

  .ha-panel-right {
    width: 150px;
    padding: 14px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }

  .ha-score-ring {
    position: relative;
    width: 64px;
    height: 64px;
  }

  .ha-ring-svg {
    width: 100%;
    height: 100%;
  }

  .ha-score-value {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    font-weight: 800;
    color: #fbbf24;
    font-family: 'Inter', system-ui, sans-serif;
    letter-spacing: -1px;
  }

  .ha-score-meta {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .ha-score-label {
    font-size: 9px;
    color: rgba(255, 255, 255, 0.3);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-family: 'Inter', system-ui, sans-serif;
  }

  .ha-score-verdict {
    font-size: 10px;
    color: #f87171;
    font-weight: 600;
    font-family: 'Inter', system-ui, sans-serif;
    min-height: 14px;
  }

  @media (prefers-reduced-motion: reduce) {
    .ha-scanline,
    .ha-result,
    .ha-panel,
    .ha-scan-overlay {
      transition: none !important;
    }

    .ha-scanline {
      display: none;
    }

    .ha-result,
    .ha-panel {
      opacity: 1;
      transform: none;
    }
  }

  @media (max-width: 768px) {
    .ha-site-content {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .ha-site-links,
    .ha-site-cards {
      display: none;
    }

    .ha-site-title {
      font-size: 14px;
    }

    .ha-site-subtitle {
      max-width: none;
    }

    .ha-panel {
      flex-direction: column;
    }

    .ha-panel-right {
      width: 100%;
      flex-direction: row;
      padding: 10px 14px;
      gap: 12px;
    }

    .ha-score-ring {
      width: 48px;
      height: 48px;
    }

    .ha-score-value {
      font-size: 16px;
    }

    .ha-score-meta {
      text-align: left;
    }
  }
</style>

<script>
  function initHeroAnimation() {
    const scanline = document.getElementById('haScanline');
    const scanOverlay = document.getElementById('haScanOverlay');
    const panel = document.getElementById('haPanel');
    const ringCircle = document.getElementById('haRingCircle');
    const scoreNum = document.getElementById('haScoreNum');
    const verdict = document.getElementById('haVerdict');
    const results = document.querySelectorAll('.ha-result');

    if (!scanline || !panel) return;

    const TARGET_SCORE = 32;
    const CIRCUMFERENCE = 2 * Math.PI * 34;

    function animateScore(target) {
      const start = performance.now();
      const duration = 1000;

      function tick(now) {
        const progress = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const val = Math.round(eased * target);

        if (scoreNum) scoreNum.textContent = String(val);
        if (ringCircle instanceof SVGCircleElement) {
          const offset = CIRCUMFERENCE - (CIRCUMFERENCE * (eased * target / 100));
          ringCircle.style.strokeDashoffset = String(offset);
        }

        if (progress < 1) requestAnimationFrame(tick);
      }

      requestAnimationFrame(tick);
    }

    function reset() {
      scanline.style.transition = 'none';
      scanline.style.top = '0';
      scanline.style.opacity = '0';
      if (scanOverlay) scanOverlay.classList.remove('active');
      panel.classList.remove('show');
      if (scoreNum) scoreNum.textContent = '0';
      if (verdict) verdict.textContent = '';
      if (ringCircle instanceof SVGCircleElement) ringCircle.style.strokeDashoffset = String(CIRCUMFERENCE);

      results.forEach((result) => {
        result.classList.remove('show', 'is-found', 'is-missing', 'is-warning');
        const badge = result.querySelector('.ha-r-badge');
        if (badge instanceof HTMLElement) {
          badge.textContent = '';
          badge.className = 'ha-r-badge';
        }
      });
    }

    function run() {
      reset();

      setTimeout(() => {
        scanline.style.opacity = '1';
        scanline.style.transition = 'top 3s cubic-bezier(0.4,0,0.2,1), opacity 0.4s';
        scanline.style.top = '250px';
        if (scanOverlay) scanOverlay.classList.add('active');
      }, 300);

      results.forEach((result) => {
        const delay = parseInt(result.getAttribute('data-delay') || '1000', 10);
        const status = result.getAttribute('data-status') || 'missing';
        const label = result.getAttribute('data-label') || '';

        setTimeout(() => {
          result.classList.add('show', `is-${status}`);
          const badge = result.querySelector('.ha-r-badge');
          if (badge instanceof HTMLElement) {
            badge.textContent = label;
            if (status === 'warning') badge.classList.add('warn');
            else badge.classList.add(status === 'found' ? 'ok' : 'no');
          }
        }, delay);
      });

      setTimeout(() => {
        scanline.style.opacity = '0';
        if (scanOverlay) scanOverlay.classList.remove('active');
        panel.classList.add('show');
        animateScore(TARGET_SCORE);
        setTimeout(() => {
          if (verdict) verdict.textContent = 'Lav synlighed';
        }, 600);
      }, 3000);

      setTimeout(() => {
        setTimeout(run, 800);
      }, 7200);
    }

    const observer = new IntersectionObserver((entries) => {
      if (entries[0]?.isIntersecting) {
        run();
        observer.disconnect();
      }
    }, { threshold: 0.3 });

    const container = document.querySelector('.hero-anim');
    if (container) observer.observe(container);
  }

  document.addEventListener('DOMContentLoaded', initHeroAnimation);
</script>

---
---
<div class="hero-anim mx-auto max-w-xl mt-12 mb-4" aria-hidden="true">
  <!-- Browser mockup -->
  <div class="ha-browser">
    <div class="ha-chrome">
      <div class="ha-dots"><span></span><span></span><span></span></div>
      <div class="ha-url"><span class="ha-lock">&#9679;</span> ditfirma.dk</div>
    </div>
    <div class="ha-page">
      <!-- Scan line -->
      <div class="ha-scanline" id="haScanline"></div>

      <!-- Realistic mini-website -->
      <div class="ha-site">
        <!-- Nav -->
        <div class="ha-site-nav">
          <div class="ha-site-logo">
            <div class="ha-logo-dot"></div>
            <span class="ha-logo-text">FirmaNavn</span>
          </div>
          <div class="ha-site-links">
            <span>Ydelser</span>
            <span>Om os</span>
            <span>Cases</span>
            <span class="ha-nav-cta">Kontakt</span>
          </div>
        </div>

        <!-- Hero area -->
        <div class="ha-site-hero">
          <div class="ha-site-title">Vi hjælper danske virksomheder med at vækste</div>
          <div class="ha-site-subtitle">Rådgivning og strategi til B2B-virksomheder der vil mere.</div>
          <div class="ha-site-btns">
            <span class="ha-btn-primary">Book et møde</span>
            <span class="ha-btn-ghost">Se cases &#8594;</span>
          </div>
        </div>

        <!-- Feature cards -->
        <div class="ha-site-cards">
          <div class="ha-card">
            <div class="ha-card-icon" style="background:rgba(6,182,212,0.12)"></div>
            <div class="ha-card-title">Strategi</div>
            <div class="ha-card-text">Vi lægger planen</div>
          </div>
          <div class="ha-card">
            <div class="ha-card-icon" style="background:rgba(251,191,36,0.12)"></div>
            <div class="ha-card-title">Marketing</div>
            <div class="ha-card-text">Synlighed der virker</div>
          </div>
          <div class="ha-card">
            <div class="ha-card-icon" style="background:rgba(34,197,94,0.12)"></div>
            <div class="ha-card-title">Drift</div>
            <div class="ha-card-text">Vi holder det kørende</div>
          </div>
        </div>
      </div>

      <!-- Scan overlay glow -->
      <div class="ha-scan-overlay" id="haScanOverlay"></div>
    </div>
  </div>

  <!-- Results panel below browser -->
  <div class="ha-panel" id="haPanel">
    <div class="ha-panel-left">
      <div class="ha-platforms" id="haResults">
        <div class="ha-result" data-status="found" data-delay="1000">
          <div class="ha-r-icon ha-chatgpt">
            <svg viewBox="0 0 24 24" fill="currentColor" width="12" height="12"><path d="M22.282 9.821a5.985 5.985 0 0 0-.516-4.91 6.046 6.046 0 0 0-6.51-2.9A6.065 6.065 0 0 0 4.981 4.18a5.985 5.985 0 0 0-3.998 2.9 6.046 6.046 0 0 0 .743 7.097 5.98 5.98 0 0 0 .51 4.911 6.051 6.051 0 0 0 6.515 2.9A5.985 5.985 0 0 0 13.26 24a6.056 6.056 0 0 0 5.772-4.206 5.99 5.99 0 0 0 3.997-2.9 6.056 6.056 0 0 0-.747-7.073zM13.26 22.43a4.476 4.476 0 0 1-2.876-1.04l.141-.081 4.779-2.758a.795.795 0 0 0 .392-.681v-6.737l2.02 1.168a.071.071 0 0 1 .038.052v5.583a4.504 4.504 0 0 1-4.494 4.494zM3.6 18.304a4.47 4.47 0 0 1-.535-3.014l.142.085 4.783 2.759a.771.771 0 0 0 .78 0l5.843-3.369v2.332a.08.08 0 0 1-.033.062L9.74 19.95a4.5 4.5 0 0 1-6.14-1.646zM2.34 7.896a4.485 4.485 0 0 1 2.366-1.973V11.6a.766.766 0 0 0 .388.676l5.815 3.355-2.02 1.168a.076.076 0 0 1-.071 0l-4.83-2.786A4.504 4.504 0 0 1 2.34 7.872zm16.597 3.855l-5.833-3.387L15.119 7.2a.076.076 0 0 1 .071 0l4.83 2.791a4.494 4.494 0 0 1-.676 8.105v-5.678a.79.79 0 0 0-.407-.667zm2.01-3.023l-.141-.085-4.774-2.782a.776.776 0 0 0-.785 0L9.409 9.23V6.897a.066.066 0 0 1 .028-.061l4.83-2.787a4.5 4.5 0 0 1 6.68 4.66zm-12.64 4.135l-2.02-1.164a.08.08 0 0 1-.038-.057V6.075a4.5 4.5 0 0 1 7.375-3.453l-.142.08L8.704 5.46a.795.795 0 0 0-.393.681zm1.097-2.365l2.602-1.5 2.607 1.5v2.999l-2.597 1.5-2.612-1.5z"/></svg>
          </div>
          <span class="ha-r-name">ChatGPT</span>
          <span class="ha-r-badge"></span>
        </div>
        <div class="ha-result" data-status="missing" data-delay="1600">
          <div class="ha-r-icon ha-claude">
            <svg viewBox="0 0 24 24" fill="currentColor" width="12" height="12"><path d="M4.709 15.955l4.397-2.008L4.71 8.042l-.003 7.913zm7.5-4.024L6.291 15.1l5.917 2.869 5.502-2.863-5.5-4.176zm6.074 4.076l-4.385-1.994 4.382 5.902.003-3.908zM12.213 2l-7.5 5.2v9.6l7.5 5.2 7.5-5.2V7.2L12.213 2z"/></svg>
          </div>
          <span class="ha-r-name">Claude</span>
          <span class="ha-r-badge"></span>
        </div>
        <div class="ha-result" data-status="missing" data-delay="2200">
          <div class="ha-r-icon ha-google">
            <svg viewBox="0 0 24 24" fill="currentColor" width="12" height="12"><path d="M12.48 10.92v3.28h7.84c-.24 1.84-.853 3.187-1.787 4.133-1.147 1.147-2.933 2.4-6.053 2.4-4.827 0-8.6-3.893-8.6-8.72s3.773-8.72 8.6-8.72c2.6 0 4.507 1.027 5.907 2.347l2.307-2.307C18.747 1.44 16.133 0 12.48 0 5.867 0 .307 5.387.307 12s5.56 12 12.173 12c3.573 0 6.267-1.173 8.373-3.36 2.16-2.16 2.84-5.213 2.84-7.667 0-.76-.053-1.467-.173-2.053H12.48z"/></svg>
          </div>
          <span class="ha-r-name">Google AI</span>
          <span class="ha-r-badge"></span>
        </div>
        <div class="ha-result" data-status="found" data-delay="2800">
          <div class="ha-r-icon ha-gemini">
            <svg viewBox="0 0 24 24" fill="currentColor" width="12" height="12"><path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zm0 2.824a9.176 9.176 0 1 1 0 18.352 9.176 9.176 0 0 1 0-18.352zM8.5 9a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3zm7 0a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3zM7.5 14.5s1.5 3 4.5 3 4.5-3 4.5-3"/></svg>
          </div>
          <span class="ha-r-name">Gemini</span>
          <span class="ha-r-badge"></span>
        </div>
      </div>
    </div>
    <div class="ha-panel-right" id="haScoreArea">
      <div class="ha-score-ring">
        <svg viewBox="0 0 80 80" class="ha-ring-svg">
          <circle cx="40" cy="40" r="34" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="5"/>
          <circle cx="40" cy="40" r="34" fill="none" stroke="url(#scoreGrad)" stroke-width="5" stroke-linecap="round" stroke-dasharray="213.6" stroke-dashoffset="213.6" transform="rotate(-90 40 40)" id="haRingCircle"/>
          <defs>
            <linearGradient id="scoreGrad" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="#ef4444"/>
              <stop offset="100%" stop-color="#fbbf24"/>
            </linearGradient>
          </defs>
        </svg>
        <div class="ha-score-value" id="haScoreNum">0</div>
      </div>
      <div class="ha-score-meta">
        <span class="ha-score-label">AI-synlighed</span>
        <span class="ha-score-verdict" id="haVerdict"></span>
      </div>
    </div>
  </div>
</div>

<style>
  .hero-anim {
    position: relative;
  }

  /* Browser frame */
  .ha-browser {
    background: rgba(2,6,23,0.85);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    overflow: hidden;
    box-shadow:
      0 24px 80px -12px rgba(0,0,0,0.5),
      0 0 0 1px rgba(255,255,255,0.03),
      0 0 60px -20px rgba(6,182,212,0.08);
  }

  .ha-chrome {
    height: 36px;
    background: rgba(15,23,42,0.9);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    display: flex;
    align-items: center;
    padding: 0 14px;
    gap: 8px;
  }

  .ha-dots { display: flex; gap: 6px; }
  .ha-dots span {
    width: 8px; height: 8px;
    border-radius: 50%;
    display: block;
  }
  .ha-dots span:nth-child(1) { background: rgba(239,68,68,0.5); }
  .ha-dots span:nth-child(2) { background: rgba(251,191,36,0.5); }
  .ha-dots span:nth-child(3) { background: rgba(34,197,94,0.5); }

  .ha-url {
    flex: 1;
    height: 22px;
    background: rgba(255,255,255,0.05);
    border-radius: 6px;
    margin-left: 8px;
    display: flex;
    align-items: center;
    padding: 0 10px;
    font-size: 11px;
    color: rgba(255,255,255,0.3);
    font-family: 'Inter', system-ui, sans-serif;
  }

  .ha-lock {
    color: rgba(34,197,94,0.6);
    font-size: 5px;
    margin-right: 6px;
  }

  /* Page content */
  .ha-page {
    padding: 16px 20px 20px;
    position: relative;
    min-height: 200px;
    overflow: hidden;
  }

  /* Realistic site mockup */
  .ha-site {
    font-family: 'Inter', system-ui, sans-serif;
    position: relative;
    z-index: 1;
  }

  .ha-site-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    margin-bottom: 16px;
  }

  .ha-site-logo {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .ha-logo-dot {
    width: 8px;
    height: 8px;
    border-radius: 2px;
    background: rgba(6,182,212,0.6);
  }

  .ha-logo-text {
    font-size: 9px;
    font-weight: 700;
    color: rgba(255,255,255,0.5);
    letter-spacing: 0.3px;
  }

  .ha-site-links {
    display: flex;
    gap: 12px;
    font-size: 7px;
    color: rgba(255,255,255,0.25);
    font-weight: 500;
  }

  .ha-nav-cta {
    background: rgba(6,182,212,0.12);
    color: rgba(6,182,212,0.6);
    padding: 2px 8px;
    border-radius: 3px;
  }

  .ha-site-hero {
    text-align: center;
    padding: 8px 0 14px;
  }

  .ha-site-title {
    font-size: 12px;
    font-weight: 700;
    color: rgba(255,255,255,0.5);
    line-height: 1.3;
    max-width: 200px;
    margin: 0 auto 5px;
  }

  .ha-site-subtitle {
    font-size: 7px;
    color: rgba(255,255,255,0.2);
    max-width: 180px;
    margin: 0 auto 10px;
    line-height: 1.5;
  }

  .ha-site-btns {
    display: flex;
    justify-content: center;
    gap: 6px;
  }

  .ha-btn-primary {
    font-size: 6px;
    font-weight: 600;
    background: rgba(251,191,36,0.25);
    color: rgba(251,191,36,0.9);
    padding: 4px 12px;
    border-radius: 3px;
  }

  .ha-btn-ghost {
    font-size: 6px;
    font-weight: 500;
    border: 1px solid rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.3);
    padding: 4px 12px;
    border-radius: 3px;
  }

  .ha-site-cards {
    display: flex;
    gap: 8px;
    justify-content: center;
  }

  .ha-card {
    flex: 1;
    max-width: 100px;
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 6px;
    padding: 8px;
  }

  .ha-card-icon {
    width: 14px;
    height: 14px;
    border-radius: 3px;
    margin-bottom: 4px;
  }

  .ha-card-title {
    font-size: 6px;
    font-weight: 600;
    color: rgba(255,255,255,0.35);
    margin-bottom: 2px;
  }

  .ha-card-text {
    font-size: 5px;
    color: rgba(255,255,255,0.15);
    line-height: 1.4;
  }

  /* Scan line */
  .ha-scanline {
    position: absolute;
    left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent 0%, rgba(6,182,212,0.4) 15%, rgba(6,182,212,1) 50%, rgba(6,182,212,0.4) 85%, transparent 100%);
    box-shadow: 0 0 16px 4px rgba(6,182,212,0.2), 0 0 40px 8px rgba(6,182,212,0.06);
    top: 0;
    opacity: 0;
    z-index: 10;
    pointer-events: none;
    transition: top 3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s;
  }

  .ha-scanline::after {
    content: '';
    position: absolute;
    left: 0; right: 0;
    top: 0;
    height: 60px;
    background: linear-gradient(180deg, rgba(6,182,212,0.05) 0%, transparent 100%);
  }

  .ha-scan-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(6,182,212,0.02) 0%, transparent 40%);
    opacity: 0;
    transition: opacity 0.6s;
    pointer-events: none;
    z-index: 2;
  }

  .ha-scan-overlay.active { opacity: 1; }

  /* Results panel */
  .ha-panel {
    margin-top: 12px;
    display: flex;
    gap: 12px;
    align-items: stretch;
    opacity: 0;
    transform: translateY(8px);
    transition: all 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .ha-panel.show {
    opacity: 1;
    transform: translateY(0);
  }

  .ha-panel-left {
    flex: 1;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 10px;
    padding: 12px;
  }

  .ha-platforms {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
  }

  .ha-result {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 10px;
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.04);
    border-radius: 8px;
    opacity: 0;
    transform: scale(0.95);
    transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .ha-result.show {
    opacity: 1;
    transform: scale(1);
  }

  .ha-result.is-found {
    border-color: rgba(34,197,94,0.25);
    background: rgba(34,197,94,0.05);
  }

  .ha-result.is-missing {
    border-color: rgba(239,68,68,0.2);
    background: rgba(239,68,68,0.04);
  }

  .ha-r-icon {
    width: 24px; height: 24px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .ha-chatgpt { background: rgba(16,163,127,0.15); color: #10a37f; }
  .ha-claude  { background: rgba(217,119,62,0.15); color: #d9773e; }
  .ha-google  { background: rgba(66,133,244,0.15); color: #4285f4; }
  .ha-gemini  { background: rgba(138,100,255,0.15); color: #8a64ff; }

  .ha-r-name {
    font-size: 11px;
    color: rgba(255,255,255,0.4);
    font-weight: 500;
    font-family: 'Inter', system-ui, sans-serif;
    flex: 1;
  }

  .ha-r-badge {
    font-size: 11px;
    font-weight: 700;
    font-family: 'Inter', system-ui, sans-serif;
  }

  .ha-r-badge.ok { color: #4ade80; }
  .ha-r-badge.no { color: #f87171; }

  /* Score ring */
  .ha-panel-right {
    width: 130px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 10px;
    padding: 14px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }

  .ha-score-ring {
    position: relative;
    width: 64px;
    height: 64px;
  }

  .ha-ring-svg {
    width: 100%;
    height: 100%;
  }

  .ha-score-value {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    font-weight: 800;
    color: #fbbf24;
    font-family: 'Inter', system-ui, sans-serif;
    letter-spacing: -1px;
  }

  .ha-score-meta {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .ha-score-label {
    font-size: 9px;
    color: rgba(255,255,255,0.3);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-family: 'Inter', system-ui, sans-serif;
  }

  .ha-score-verdict {
    font-size: 9px;
    color: #f87171;
    font-weight: 600;
    font-family: 'Inter', system-ui, sans-serif;
    min-height: 14px;
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .ha-scanline, .ha-result, .ha-panel, .ha-scan-overlay {
      transition: none !important;
    }
    .ha-scanline { display: none; }
    .ha-result { opacity: 1; transform: none; }
    .ha-panel { opacity: 1; transform: none; }
  }

  /* Responsive */
  @media (max-width: 640px) {
    .ha-site-links { display: none; }
    .ha-site-cards { display: none; }
    .ha-site-title { font-size: 11px; }

    .ha-panel {
      flex-direction: column;
    }
    .ha-panel-right {
      width: 100%;
      flex-direction: row;
      padding: 10px 14px;
      gap: 12px;
    }
    .ha-score-ring {
      width: 48px;
      height: 48px;
    }
    .ha-score-value { font-size: 16px; }
    .ha-score-meta {
      text-align: left;
    }
  }
</style>

<script>
  function initHeroAnimation() {
    const scanline = document.getElementById('haScanline');
    const scanOverlay = document.getElementById('haScanOverlay');
    const panel = document.getElementById('haPanel');
    const ringCircle = document.getElementById('haRingCircle') as SVGCircleElement | null;
    const scoreNum = document.getElementById('haScoreNum');
    const verdict = document.getElementById('haVerdict');
    const results = document.querySelectorAll('.ha-result');

    if (!scanline || !panel) return;

    const TARGET_SCORE = 34;
    const CIRCUMFERENCE = 2 * Math.PI * 34; // r=34

    function animateScore(target: number) {
      const start = performance.now();
      const duration = 1000;
      function tick(now: number) {
        const progress = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const val = Math.round(eased * target);
        if (scoreNum) scoreNum.textContent = String(val);
        if (ringCircle) {
          const offset = CIRCUMFERENCE - (CIRCUMFERENCE * (eased * target / 100));
          ringCircle.style.strokeDashoffset = String(offset);
        }
        if (progress < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }

    function reset() {
      scanline.style.transition = 'none';
      scanline.style.top = '0';
      scanline.style.opacity = '0';
      if (scanOverlay) scanOverlay.classList.remove('active');
      panel.classList.remove('show');
      if (scoreNum) scoreNum.textContent = '0';
      if (verdict) verdict.textContent = '';
      if (ringCircle) ringCircle.style.strokeDashoffset = String(CIRCUMFERENCE);
      results.forEach(r => {
        r.classList.remove('show', 'is-found', 'is-missing');
        const badge = r.querySelector('.ha-r-badge') as HTMLElement;
        if (badge) { badge.textContent = ''; badge.className = 'ha-r-badge'; }
      });
    }

    function run() {
      reset();

      // Start scan
      setTimeout(() => {
        scanline.style.opacity = '1';
        scanline.style.transition = 'top 3s cubic-bezier(0.4,0,0.2,1), opacity 0.4s';
        scanline.style.top = '200px';
        if (scanOverlay) scanOverlay.classList.add('active');
      }, 300);

      // Show platform results staggered
      results.forEach(r => {
        const delay = parseInt(r.getAttribute('data-delay') || '1000');
        const found = r.getAttribute('data-status') === 'found';
        setTimeout(() => {
          r.classList.add('show', found ? 'is-found' : 'is-missing');
          const badge = r.querySelector('.ha-r-badge') as HTMLElement;
          if (badge) {
            badge.textContent = found ? 'Fundet' : 'Mangler';
            badge.classList.add(found ? 'ok' : 'no');
          }
        }, delay);
      });

      // Show panel with score
      setTimeout(() => {
        scanline.style.opacity = '0';
        if (scanOverlay) scanOverlay.classList.remove('active');
        panel.classList.add('show');
        animateScore(TARGET_SCORE);
        setTimeout(() => {
          if (verdict) verdict.textContent = 'Lav synlighed';
        }, 600);
      }, 3400);

      // Hold, then loop
      setTimeout(() => {
        setTimeout(run, 800);
      }, 7500);
    }

    // Start when visible
    const observer = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting) {
        run();
        observer.disconnect();
      }
    }, { threshold: 0.3 });

    const container = document.querySelector('.hero-anim');
    if (container) observer.observe(container);
  }

  document.addEventListener('DOMContentLoaded', initHeroAnimation);
</script>

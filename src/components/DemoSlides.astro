---

<section id="demo" class="bg-gray-50 border-b border-gray-200">
  <div class="max-w-5xl mx-auto px-6 py-20 md:py-28">
    <div class="max-w-2xl mb-10">
      <p class="text-sm text-accent font-semibold uppercase tracking-wider mb-3">Demo</p>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-brand tracking-tight mb-4">
        Se hvordan kundeoplevelsen ser ud
      </h2>
      <p class="text-gray-500">
        Et eksempel på et Client Room for den fiktive virksomhed "Nordisk Køkken". Din leverance vil være tilpasset din virksomhed med rigtige data.
      </p>
    </div>

    <div class="flex gap-1 mb-8 overflow-x-auto -mx-6 px-6 scrollbar-hide" role="tablist" aria-label="Demosektioner">
      {slides.map((slide, i) => (
        <button
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
          aria-controls={`panel-${slide.id}`}
          id={`tab-${slide.id}`}
          class:list={[
            'demo-tab flex-shrink-0 px-5 py-2.5 text-sm font-semibold rounded-full transition-colors whitespace-nowrap',
            i === 0 ? 'bg-brand text-white' : 'bg-white text-gray-500 border border-gray-200 hover:border-gray-300',
          ]}
          data-index={i}
        >
          {slide.label}
        </button>
      ))}
    </div>

    <!-- Slide panels -->
    <div class="relative">
      {slides.map((slide, i) => (
        <div
          role="tabpanel"
          id={`panel-${slide.id}`}
          aria-labelledby={`tab-${slide.id}`}
          class:list={['demo-panel bg-white border border-gray-200 rounded-xl p-6 md:p-8', i !== 0 && 'hidden']}
          data-index={i}
        >
          <h3 class="font-display text-lg font-bold text-brand mb-5">{slide.title}</h3>
          <Fragment set:html={slide.content} />
        </div>
      ))}
    </div>

    <!-- Navigation arrows + slide counter -->
    <div class="flex items-center justify-between mt-6">
      <button id="demo-prev" class="flex items-center gap-2 text-sm text-gray-400 hover:text-brand transition-colors disabled:opacity-30" disabled>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
        Forrige
      </button>
      <span id="demo-counter" class="text-xs text-gray-400">1 / 4</span>
      <button id="demo-next" class="flex items-center gap-2 text-sm text-gray-400 hover:text-brand transition-colors">
        Næste
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
      </button>
    </div>
  </div>
</section>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.demo-tab');
  const panels = document.querySelectorAll<HTMLDivElement>('.demo-panel');
  const prev = document.getElementById('demo-prev') as HTMLButtonElement;
  const next = document.getElementById('demo-next') as HTMLButtonElement;
  const counter = document.getElementById('demo-counter');
  const total = tabs.length;
  let current = 0;

  function goTo(index: number) {
    current = Math.max(0, Math.min(total - 1, index));
    tabs.forEach((tab, i) => {
      const active = i === current;
      tab.setAttribute('aria-selected', String(active));
      tab.classList.toggle('bg-brand', active);
      tab.classList.toggle('text-white', active);
      tab.classList.toggle('bg-white', !active);
      tab.classList.toggle('text-gray-500', !active);
      tab.classList.toggle('border', !active);
      tab.classList.toggle('border-gray-200', !active);
    });
    panels.forEach((panel, i) => panel.classList.toggle('hidden', i !== current));
    prev.disabled = current === 0;
    next.disabled = current === total - 1;
    if (counter) counter.textContent = `${current + 1} / ${total}`;
  }

  tabs.forEach((tab) => tab.addEventListener('click', () => goTo(Number(tab.dataset.index))));
  prev.addEventListener('click', () => goTo(current - 1));
  next.addEventListener('click', () => goTo(current + 1));

  // Swipe support
  let startX = 0;
  const container = panels[0]?.parentElement;
  if (container) {
    container.addEventListener('touchstart', (e) => { startX = e.touches[0].clientX; }, { passive: true });
    container.addEventListener('touchend', (e) => {
      const diff = startX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 50) goTo(current + (diff > 0 ? 1 : -1));
    });
  }
</script>

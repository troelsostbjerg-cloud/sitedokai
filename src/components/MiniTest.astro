---
---
<section id="mini-test" class="bg-white border-b border-gray-200">
  <div class="max-w-5xl mx-auto px-6 py-16 md:py-24">
    <div class="max-w-2xl mx-auto text-center">
      <p class="text-sm text-accent font-semibold uppercase tracking-wider mb-3">Gratis hurtigestimat</p>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-brand tracking-tight mb-4">
        Få et hurtigt AI-synlighedsestimat
      </h2>
      <p class="text-gray-500 mb-10">
        Indtast din URL. Vi giver et foreløbigt estimat baseret på offentlige domæne- og brandsignaler. Den fulde audit laver de rigtige live tests på ChatGPT, Gemini, Google AI og Claude.
      </p>

      <form id="mini-test-form" class="max-w-lg mx-auto">
        <div class="flex flex-col sm:flex-row gap-3">
          <input
            type="text"
            id="mini-test-url"
            placeholder="www.dinvirksomhed.dk"
            inputmode="url"
            autocomplete="url"
            autocapitalize="none"
            spellcheck="false"
            class="flex-1 px-5 py-4 border border-gray-300 text-brand bg-white placeholder-gray-400 font-medium focus:outline-none focus:ring-2 focus:ring-accent rounded-md"
          />
          <button
            id="mini-test-btn"
            type="submit"
            class="bg-amber-400 text-brand px-8 py-4 font-bold text-lg hover:bg-amber-300 transition-colors rounded-md whitespace-nowrap"
          >
            Kør hurtigestimat
          </button>
        </div>
        <p class="text-xs text-gray-400 mt-3">
          Ingen email. Ingen forpligtelser. Dette er et foreløbigt estimat, ikke en live test i AI-platformene.
        </p>
      </form>

      <!-- Loading state with transparent estimation steps -->
      <div id="mini-test-loading" class="hidden max-w-lg mx-auto mt-10">
        <div class="space-y-3 text-left">
          <div id="step-1" class="flex items-center gap-3 text-gray-400">
            <svg class="w-5 h-5 animate-spin flex-shrink-0" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            <span class="text-sm">Normaliserer domæne og URL...</span>
          </div>
          <div id="step-2" class="flex items-center gap-3 text-gray-300 hidden">
            <svg class="w-5 h-5 animate-spin flex-shrink-0" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            <span class="text-sm">Vurderer domæne- og brandsignaler...</span>
          </div>
          <div id="step-3" class="flex items-center gap-3 text-gray-300 hidden">
            <svg class="w-5 h-5 animate-spin flex-shrink-0" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            <span class="text-sm">Genererer et foreløbigt estimat...</span>
          </div>
        </div>
      </div>

      <!-- Result -->
      <div id="mini-test-result" class="hidden max-w-lg mx-auto mt-10">
        <div class="bg-gray-50 border border-gray-200 rounded-xl p-6 md:p-8 text-left">

          <!-- AI Visibility estimate -->
          <div class="text-center mb-8">
            <p class="text-xs text-gray-400 uppercase tracking-wider font-semibold mb-3">Foreløbigt AI-estimat</p>
            <div class="inline-flex items-end gap-1.5 mb-2">
              <span id="mini-result-score" class="font-display text-5xl md:text-6xl font-extrabold"></span>
              <span class="text-xl text-gray-300 font-bold mb-1.5">/100</span>
            </div>
            <div>
              <span id="mini-result-grade" class="text-sm font-bold px-4 py-1.5 rounded-full inline-block"></span>
            </div>
            <p class="text-xs text-gray-400 mt-3 max-w-md mx-auto">
              Hurtigtesten vurderer kun offentlige domæne- og brandsignaler. Den kan ikke bekræfte om du faktisk nævnes i ChatGPT eller Google AI.
            </p>
          </div>

          <!-- Quick signal breakdown -->
          <div class="space-y-4 mb-6">
            <p class="text-xs text-gray-400 uppercase tracking-wider font-semibold">Hurtigsignaler</p>

            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
              <div class="bg-white border border-gray-200 rounded-lg p-3.5">
                <div class="flex items-center justify-between gap-2 mb-1">
                  <span class="text-sm font-semibold text-brand">Domæneklarhed</span>
                  <span id="signal-domain-badge" class="text-[10px] font-bold px-2 py-0.5 rounded-full"></span>
                </div>
                <p id="signal-domain-detail" class="text-xs text-gray-400"></p>
              </div>
              <div class="bg-white border border-gray-200 rounded-lg p-3.5">
                <div class="flex items-center justify-between gap-2 mb-1">
                  <span class="text-sm font-semibold text-brand">Dansk signal</span>
                  <span id="signal-local-badge" class="text-[10px] font-bold px-2 py-0.5 rounded-full"></span>
                </div>
                <p id="signal-local-detail" class="text-xs text-gray-400"></p>
              </div>
              <div class="bg-white border border-gray-200 rounded-lg p-3.5">
                <div class="flex items-center justify-between gap-2 mb-1">
                  <span class="text-sm font-semibold text-brand">Entitetsignal</span>
                  <span id="signal-entity-badge" class="text-[10px] font-bold px-2 py-0.5 rounded-full"></span>
                </div>
                <p id="signal-entity-detail" class="text-xs text-gray-400"></p>
              </div>
            </div>
          </div>

          <!-- Key framing -->
          <div id="mini-result-risk" class="bg-amber-50 border border-amber-100 rounded-lg p-4 mb-6">
            <div class="flex gap-3">
              <svg class="w-5 h-5 text-amber-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              <div>
                <p class="text-sm font-semibold text-brand" id="mini-risk-title"></p>
                <p class="text-xs text-gray-500 mt-0.5" id="mini-risk-detail"></p>
              </div>
            </div>
          </div>

          <div class="bg-white border border-gray-200 rounded-lg p-4 mb-6">
            <p class="text-xs text-gray-400 uppercase tracking-wider font-semibold">Det kræver fuld audit</p>
            <ul class="mt-3 space-y-2 text-sm text-gray-600">
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 mt-0.5 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                <span>Live prompttests på ChatGPT, Gemini, Google AI og Claude</span>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 mt-0.5 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                <span>Konkurrentbenchmark og kildeanalyse på tværs af relevante søgninger</span>
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 mt-0.5 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                <span>Prioriterede forbedringer med konkret forklaring på hvad der skal løses først</span>
              </li>
            </ul>
          </div>

          <!-- CTA -->
          <div class="border-t border-gray-200 pt-5 text-center">
            <p class="text-sm text-gray-500 mb-4">
              Den fulde audit tester med <strong class="text-brand">50+ søgninger</strong> og viser hvilke platforme, kilder og konkurrenter der fylder i praksis.
            </p>
            <a href="#contact" class="inline-block bg-amber-400 text-brand px-8 py-3.5 font-bold text-lg hover:bg-amber-300 transition-colors rounded-md">
              Få den fulde audit — 2.495 kr
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
(function() {
  var form = document.getElementById('mini-test-form');
  var input = document.getElementById('mini-test-url');
  var loading = document.getElementById('mini-test-loading');
  var result = document.getElementById('mini-test-result');
  var riskBox = document.getElementById('mini-result-risk');
  var scoreEl = document.getElementById('mini-result-score');
  var gradeEl = document.getElementById('mini-result-grade');
  var riskTitle = document.getElementById('mini-risk-title');
  var riskDetail = document.getElementById('mini-risk-detail');
  var step1 = document.getElementById('step-1');
  var step2 = document.getElementById('step-2');
  var step3 = document.getElementById('step-3');

  if (!form || !input || !loading || !result || !riskBox || !scoreEl || !gradeEl || !riskTitle || !riskDetail || !step1 || !step2 || !step3) return;

  function spinnerMarkup(text) {
    return '<svg class="w-5 h-5 animate-spin flex-shrink-0" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg><span class="text-sm">' + text + '</span>';
  }

  function doneMarkup(text) {
    return '<svg class="w-5 h-5 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg><span class="text-sm text-brand">' + text + '</span>';
  }

  function resetSteps() {
    step1.className = 'flex items-center gap-3 text-gray-400';
    step2.className = 'flex items-center gap-3 text-gray-300 hidden';
    step3.className = 'flex items-center gap-3 text-gray-300 hidden';
    step1.innerHTML = spinnerMarkup('Normaliserer domæne og URL...');
    step2.innerHTML = spinnerMarkup('Vurderer domæne- og brandsignaler...');
    step3.innerHTML = spinnerMarkup('Genererer et foreløbigt estimat...');
  }

  function badgeClass(tone) {
    if (tone === 'green') return 'text-[10px] font-bold px-2 py-0.5 rounded-full bg-green-50 text-green-800';
    if (tone === 'red') return 'text-[10px] font-bold px-2 py-0.5 rounded-full bg-red-50 text-score-red';
    return 'text-[10px] font-bold px-2 py-0.5 rounded-full bg-yellow-50 text-score-yellow';
  }

  function setSignal(prefix, label, detail, tone) {
    var badge = document.getElementById(prefix + '-badge');
    var detailEl = document.getElementById(prefix + '-detail');
    if (!badge || !detailEl) return;
    badge.textContent = label;
    badge.className = badgeClass(tone);
    detailEl.textContent = detail;
  }

  form.addEventListener('submit', function(event) {
    event.preventDefault();
    var url = input.value.trim();
    if (!url) { input.focus(); return; }
    if (!/^https?:\/\//i.test(url)) url = 'https://' + url.replace(/^\/+/, '');

    form.classList.add('hidden');
    loading.classList.remove('hidden');
    result.classList.add('hidden');
    resetSteps();

    setTimeout(function() {
      step1.innerHTML = doneMarkup('Domæne og URL afklaret');
      step2.classList.remove('hidden');
    }, 800);

    setTimeout(function() {
      step2.innerHTML = doneMarkup('Hurtigsignaler vurderet');
      step3.classList.remove('hidden');
    }, 1600);

    setTimeout(function() {
      runCheck(url);
    }, 2400);
  });

  function runCheck(url) {
    var domain = url.replace(/^https?:\/\//, '').replace(/\/.*$/, '').toLowerCase();
    var cleanName = domain.replace('www.', '').split('.')[0];
    var hasDk = domain.endsWith('.dk');
    var nameLen = cleanName.length;
    var hasHyphen = cleanName.indexOf('-') !== -1;
    var hasDigits = /\d/.test(cleanName);
    var hasPath = /^https?:\/\/[^/]+\/.+/.test(url);

    var clarityPoints = 0;
    if (!hasHyphen) clarityPoints += 1;
    if (!hasDigits) clarityPoints += 1;
    if (nameLen >= 4 && nameLen <= 12) clarityPoints += 1;

    var entityPoints = 0;
    if (!hasDigits) entityPoints += 1;
    if (!hasHyphen) entityPoints += 1;
    if (nameLen <= 10) entityPoints += 1;
    if (hasDk) entityPoints += 1;

    var baseScore = 12;
    baseScore += clarityPoints * 4;
    baseScore += entityPoints * 3;
    baseScore += hasDk ? 5 : 1;
    if (nameLen > 14) baseScore -= 4;
    if (hasDigits) baseScore -= 2;

    var score = Math.max(12, Math.min(42, baseScore));
    var rangeStart = Math.max(10, score - 4);
    var rangeEnd = Math.min(46, score + 4);

    var domainSignal;
    if (clarityPoints === 3) {
      domainSignal = {
        label: 'Stærkt',
        tone: 'green',
        detail: 'Kort og let at aflæse som brandnavn.'
      };
    } else if (clarityPoints === 2) {
      domainSignal = {
        label: 'Middel',
        tone: 'yellow',
        detail: 'Brugbart domæne, men ikke helt knivskarpt som entitet.'
      };
    } else {
      domainSignal = {
        label: 'Svagt',
        tone: 'red',
        detail: 'Domænet er sværere at aflæse hurtigt som klart brand.'
      };
    }

    var localSignal = hasDk
      ? {
          label: 'Stærkt',
          tone: 'green',
          detail: '.dk giver et tydeligt dansk markedssignal.'
        }
      : {
          label: 'Neutral',
          tone: 'yellow',
          detail: 'Domænet giver ikke i sig selv et tydeligt dansk signal.'
        };

    if (hasPath) {
      localSignal.detail += ' Hurtigtesten vurderer kun hoveddomænet.';
    }

    var entitySignal;
    if (entityPoints >= 4) {
      entitySignal = {
        label: 'Stærkt',
        tone: 'green',
        detail: 'Brandet ser relativt let ud at koble til én tydelig virksomhed.'
      };
    } else if (entityPoints >= 2) {
      entitySignal = {
        label: 'Middel',
        tone: 'yellow',
        detail: 'Der er noget signal, men AI vil have brug for stærkere kilder og struktur.'
      };
    } else {
      entitySignal = {
        label: 'Svagt',
        tone: 'red',
        detail: 'Udgangspunktet ligner noget der typisk kræver mere støtte fra kilder og struktur.'
      };
    }

    scoreEl.textContent = rangeStart + '-' + rangeEnd;
    scoreEl.style.color = score < 20 ? '#cb2431' : score < 30 ? '#b08800' : '#0f766e';

    if (score < 20) {
      gradeEl.textContent = 'Høj risiko — svagt udgangspunkt';
      gradeEl.className = 'text-sm font-bold px-4 py-1.5 rounded-full inline-block bg-red-50 text-score-red';
      riskBox.className = 'bg-red-50 border border-red-100 rounded-lg p-4 mb-6';
      riskTitle.textContent = 'Dit udgangspunkt ligner mange virksomheder som ofte er usynlige i AI-svar';
      riskDetail.textContent = 'Et uklart brandnavn eller svagere markedssignal gør det lettere for AI at læne sig på stærkere konkurrenter og tydeligere kilder.';
    } else if (score < 30) {
      gradeEl.textContent = 'Foreløbigt svagt — kræver live test';
      gradeEl.className = 'text-sm font-bold px-4 py-1.5 rounded-full inline-block bg-yellow-50 text-score-yellow';
      riskBox.className = 'bg-amber-50 border border-amber-100 rounded-lg p-4 mb-6';
      riskTitle.textContent = 'Der er nogle brugbare signaler, men hurtigtesten kan ikke bekræfte reel synlighed';
      riskDetail.textContent = 'Nu giver det mest mening at teste live prompts, konkurrenter og kilder før du drager en konklusion om din AI-synlighed.';
    } else {
      gradeEl.textContent = 'Muligt udgangspunkt — ikke bekræftet';
      gradeEl.className = 'text-sm font-bold px-4 py-1.5 rounded-full inline-block bg-green-50 text-green-800';
      riskBox.className = 'bg-green-50 border border-green-100 rounded-lg p-4 mb-6';
      riskTitle.textContent = 'Du har et bedre udgangspunkt end gennemsnittet, men den reelle test starter først i den fulde audit';
      riskDetail.textContent = 'Det kræver live prompttests og kildeanalyse at se om AI faktisk nævner dig fremfor konkurrenterne.';
    }

    setSignal('signal-domain', domainSignal.label, domainSignal.detail, domainSignal.tone);
    setSignal('signal-local', localSignal.label, localSignal.detail, localSignal.tone);
    setSignal('signal-entity', entitySignal.label, entitySignal.detail, entitySignal.tone);

    step3.innerHTML = doneMarkup('Foreløbigt estimat klar');
    loading.classList.add('hidden');
    result.classList.remove('hidden');
  }
})();
</script>

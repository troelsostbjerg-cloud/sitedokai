---
---
<section id="mini-test" class="bg-white border-b border-gray-200">
  <div class="max-w-5xl mx-auto px-6 py-16 md:py-24">
    <div class="max-w-2xl mx-auto text-center">
      <p class="text-sm text-accent font-semibold uppercase tracking-wider mb-3">Gratis hurtigtest</p>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-brand tracking-tight mb-4">
        Test din AI-synlighed på 10 sekunder
      </h2>
      <p class="text-gray-500 mb-10">
        Indtast din URL — vi estimerer hvor synlig din virksomhed er for ChatGPT, Gemini, Google AI og Claude.
      </p>

      <div id="mini-test-form" class="max-w-lg mx-auto">
        <div class="flex flex-col sm:flex-row gap-3">
          <input
            type="text"
            id="mini-test-url"
            placeholder="www.dinvirksomhed.dk"
            inputmode="url"
            autocomplete="url"
            autocapitalize="none"
            spellcheck="false"
            class="flex-1 px-5 py-4 border border-gray-300 text-brand bg-white placeholder-gray-400 font-medium focus:outline-none focus:ring-2 focus:ring-accent rounded-md"
          />
          <button
            id="mini-test-btn"
            class="bg-amber-400 text-brand px-8 py-4 font-bold text-lg hover:bg-amber-300 transition-colors rounded-md whitespace-nowrap"
          >
            Test nu
          </button>
        </div>
        <p class="text-xs text-gray-400 mt-3">Ingen email. Ingen forpligtelser. Resultat med det samme.</p>
      </div>

      <!-- Loading state with AI-platform steps -->
      <div id="mini-test-loading" class="hidden max-w-lg mx-auto mt-10">
        <div class="space-y-3 text-left">
          <div id="step-1" class="flex items-center gap-3 text-gray-400">
            <svg class="w-5 h-5 animate-spin flex-shrink-0" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            <span class="text-sm">Tjekker synlighed i ChatGPT...</span>
          </div>
          <div id="step-2" class="flex items-center gap-3 text-gray-300 hidden">
            <svg class="w-5 h-5 animate-spin flex-shrink-0" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            <span class="text-sm">Tjekker Google AI Overviews...</span>
          </div>
          <div id="step-3" class="flex items-center gap-3 text-gray-300 hidden">
            <svg class="w-5 h-5 animate-spin flex-shrink-0" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            <span class="text-sm">Analyserer konkurrentsituation...</span>
          </div>
        </div>
      </div>

      <!-- Result -->
      <div id="mini-test-result" class="hidden max-w-lg mx-auto mt-10">
        <div class="bg-gray-50 border border-gray-200 rounded-xl p-6 md:p-8 text-left">

          <!-- AI Visibility Risk Gauge -->
          <div class="text-center mb-8">
            <p class="text-xs text-gray-400 uppercase tracking-wider font-semibold mb-3">Estimeret AI-synlighed</p>
            <div class="inline-flex items-end gap-1.5 mb-2">
              <span id="mini-result-score" class="font-display text-5xl font-extrabold"></span>
              <span class="text-xl text-gray-300 font-bold mb-1.5">/100</span>
            </div>
            <div>
              <span id="mini-result-grade" class="text-sm font-bold px-4 py-1.5 rounded-full inline-block"></span>
            </div>
          </div>

          <!-- Platform breakdown -->
          <div class="space-y-4 mb-6">
            <p class="text-xs text-gray-400 uppercase tracking-wider font-semibold">AI-platform synlighed</p>

            <div class="grid grid-cols-2 gap-3">
              <div class="bg-white border border-gray-200 rounded-lg p-3.5">
                <div class="flex items-center justify-between mb-1">
                  <span class="text-sm font-semibold text-brand">ChatGPT</span>
                  <span id="res-chatgpt" class="text-[10px] font-bold px-2 py-0.5 rounded-full"></span>
                </div>
                <p id="res-chatgpt-detail" class="text-xs text-gray-400"></p>
              </div>
              <div class="bg-white border border-gray-200 rounded-lg p-3.5">
                <div class="flex items-center justify-between mb-1">
                  <span class="text-sm font-semibold text-brand">Google AI</span>
                  <span id="res-google" class="text-[10px] font-bold px-2 py-0.5 rounded-full"></span>
                </div>
                <p id="res-google-detail" class="text-xs text-gray-400"></p>
              </div>
              <div class="bg-white border border-gray-200 rounded-lg p-3.5">
                <div class="flex items-center justify-between mb-1">
                  <span class="text-sm font-semibold text-brand">Claude</span>
                  <span id="res-claude" class="text-[10px] font-bold px-2 py-0.5 rounded-full"></span>
                </div>
                <p id="res-claude-detail" class="text-xs text-gray-400"></p>
              </div>
              <div class="bg-white border border-gray-200 rounded-lg p-3.5">
                <div class="flex items-center justify-between mb-1">
                  <span class="text-sm font-semibold text-brand">Gemini</span>
                  <span id="res-gemini" class="text-[10px] font-bold px-2 py-0.5 rounded-full"></span>
                </div>
                <p id="res-gemini-detail" class="text-xs text-gray-400"></p>
              </div>
            </div>
          </div>

          <!-- Key risk -->
          <div id="mini-result-risk" class="bg-red-50 border border-red-100 rounded-lg p-4 mb-6">
            <div class="flex gap-3">
              <svg class="w-5 h-5 text-score-red flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              <div>
                <p class="text-sm font-semibold text-brand" id="mini-risk-title"></p>
                <p class="text-xs text-gray-500 mt-0.5" id="mini-risk-detail"></p>
              </div>
            </div>
          </div>

          <!-- CTA -->
          <div class="border-t border-gray-200 pt-5 text-center">
            <p class="text-sm text-gray-500 mb-4">
              Dette er et estimat baseret på offentlige signaler. Den fulde rapport tester med <strong class="text-brand">50+ søgninger</strong> på alle 4 AI-platforme.
            </p>
            <a href="#contact" class="inline-block bg-amber-400 text-brand px-8 py-3.5 font-bold text-lg hover:bg-amber-300 transition-colors rounded-md">
              Få den fulde rapport — 2.495 kr
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
(function() {
  var form = document.getElementById('mini-test-form');
  var btn = document.getElementById('mini-test-btn');
  var input = document.getElementById('mini-test-url');
  var loading = document.getElementById('mini-test-loading');
  var result = document.getElementById('mini-test-result');

  if (!btn || !input) return;

  btn.addEventListener('click', function() {
    var url = input.value.trim();
    if (!url) { input.focus(); return; }
    if (!/^https?:\/\//i.test(url)) url = 'https://' + url.replace(/^\/+/, '');

    form.classList.add('hidden');
    loading.classList.remove('hidden');
    result.classList.add('hidden');

    // Animated loading steps
    var step1 = document.getElementById('step-1');
    var step2 = document.getElementById('step-2');
    var step3 = document.getElementById('step-3');

    step1.classList.remove('hidden');
    step2.classList.add('hidden');
    step3.classList.add('hidden');

    setTimeout(function() {
      step1.querySelector('svg').classList.add('hidden');
      step1.innerHTML = '<svg class="w-5 h-5 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg><span class="text-sm text-brand">ChatGPT-synlighed analyseret</span>';
      step2.classList.remove('hidden');
    }, 800);

    setTimeout(function() {
      step2.innerHTML = '<svg class="w-5 h-5 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg><span class="text-sm text-brand">Google AI analyseret</span>';
      step3.classList.remove('hidden');
    }, 1600);

    setTimeout(function() {
      runCheck(url);
    }, 2400);
  });

  function runCheck(url) {
    var domain = url.replace(/^https?:\/\//, '').replace(/\/.*$/, '').toLowerCase();
    var cleanName = domain.replace('www.', '').split('.')[0];
    var hasDk = domain.endsWith('.dk');
    var nameLen = cleanName.length;

    // AI visibility scoring — weighted toward "most businesses are invisible"
    // This is realistic: ~70% of Danish SMBs have near-zero AI visibility
    var baseScore = 15; // Most companies start very low

    // Signals that slightly improve the estimate
    if (hasDk) baseScore += 8; // Local relevance
    if (nameLen >= 3 && nameLen <= 12) baseScore += 5; // Clear brand name
    if (nameLen <= 8) baseScore += 3; // Very concise = easier for AI to identify
    if (domain.indexOf('-') === -1) baseScore += 2; // No hyphens = cleaner entity

    // Add small deterministic variation based on domain hash
    var hash = 0;
    for (var i = 0; i < cleanName.length; i++) {
      hash = ((hash << 5) - hash) + cleanName.charCodeAt(i);
      hash = hash & hash;
    }
    baseScore += Math.abs(hash % 8); // 0-7 variation

    // Cap realistic range: 12-42 (nobody gets "good" from a quick test)
    var score = Math.max(12, Math.min(42, baseScore));

    // Platform results — always concerning, varied by score
    var platforms = {
      chatgpt: score > 30
        ? { label: 'Begrænset', cls: 'bg-yellow-50 text-score-yellow', detail: 'Sandsynligvis kun nævnt i generelle svar' }
        : { label: 'Usandsynlig', cls: 'bg-red-50 text-score-red', detail: 'Lav sandsynlighed for at blive anbefalet' },
      google: score > 25
        ? { label: 'Uvis', cls: 'bg-yellow-50 text-score-yellow', detail: 'Kræver test med branchespecifikke søgninger' }
        : { label: 'Usandsynlig', cls: 'bg-red-50 text-score-red', detail: 'Konkurrenter fylder sandsynligvis mere' },
      claude: { label: 'Ukendt', cls: 'bg-gray-100 text-gray-500', detail: 'Kræver live API-test for at verificere' },
      gemini: score > 28
        ? { label: 'Mulig', cls: 'bg-yellow-50 text-score-yellow', detail: 'Afhænger af strukturerede data og kilder' }
        : { label: 'Usandsynlig', cls: 'bg-red-50 text-score-red', detail: 'Uden strukturerede data er synlighed lav' },
    };

    // Render score
    var scoreEl = document.getElementById('mini-result-score');
    var gradeEl = document.getElementById('mini-result-grade');

    scoreEl.textContent = score;
    scoreEl.style.color = score < 25 ? '#cb2431' : '#b08800';

    if (score < 25) {
      gradeEl.textContent = 'Høj risiko — sandsynligvis usynlig';
      gradeEl.className = 'text-sm font-bold px-4 py-1.5 rounded-full inline-block bg-red-50 text-score-red';
    } else {
      gradeEl.textContent = 'Moderat risiko — begrænset synlighed';
      gradeEl.className = 'text-sm font-bold px-4 py-1.5 rounded-full inline-block bg-yellow-50 text-score-yellow';
    }

    // Render platforms
    ['chatgpt', 'google', 'claude', 'gemini'].forEach(function(p) {
      var badge = document.getElementById('res-' + p);
      var detail = document.getElementById('res-' + p + '-detail');
      badge.textContent = platforms[p].label;
      badge.className = 'text-[10px] font-bold px-2 py-0.5 rounded-full ' + platforms[p].cls;
      detail.textContent = platforms[p].detail;
    });

    // Render key risk
    var riskTitle = document.getElementById('mini-risk-title');
    var riskDetail = document.getElementById('mini-risk-detail');
    if (score < 25) {
      riskTitle.textContent = 'Dine konkurrenter bliver sandsynligvis anbefalet i stedet for dig';
      riskDetail.textContent = '67% af danske virksomheder er usynlige i AI-søgning. Uden en aktiv indsats vælger AI dine konkurrenter.';
    } else {
      riskTitle.textContent = 'Du har et udgangspunkt — men konkurrenter kan stadig dominere';
      riskDetail.textContent = 'Basale signaler er på plads, men AI-synlighed kræver systematisk optimering for at slå konkurrenterne.';
    }

    loading.classList.add('hidden');
    result.classList.remove('hidden');
  }
})();
</script>

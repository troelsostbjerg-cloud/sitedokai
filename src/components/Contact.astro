---
---
<section id="contact" class="bg-white">
  <div class="max-w-5xl mx-auto px-6 py-20 md:py-28">
    <div class="max-w-xl mx-auto text-center mb-12">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-brand tracking-tight mb-4">
        Bestil din rapport
      </h2>
      <p class="text-lg text-gray-500">
        Indsend din URL. Vi leverer en komplet AI-synlighedsrapport som PDF inden for 48 timer på hverdage.
      </p>
    </div>

    <form id="contactForm" action="https://formsubmit.co/troelsostbjerg@gmail.com" method="POST" class="max-w-lg mx-auto space-y-6">
      <input type="hidden" name="_subject" value="Ny bestilling - SitedokAI rapport" />
      <input type="hidden" name="_captcha" value="false" />
      <input type="hidden" name="_template" value="table" />
      <div>
        <label for="name" class="block text-sm font-semibold text-brand mb-2">Dit navn *</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          aria-required="true"
          class="w-full px-4 py-3 border border-gray-300 text-brand placeholder-gray-400 focus:outline-none focus:border-accent transition-colors"
        />
      </div>

      <div>
        <label for="email" class="block text-sm font-semibold text-brand mb-2">Email-adresse *</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          aria-required="true"
          class="w-full px-4 py-3 border border-gray-300 text-brand placeholder-gray-400 focus:outline-none focus:border-accent transition-colors"
        />
      </div>

      <div>
        <label for="website" class="block text-sm font-semibold text-brand mb-2">Website URL *</label>
        <input
          type="url"
          id="website"
          name="website"
          placeholder="https://www.example.dk"
          required
          aria-required="true"
          class="w-full px-4 py-3 border border-gray-300 text-brand placeholder-gray-400 focus:outline-none focus:border-accent transition-colors"
        />
      </div>

      <div>
        <label for="message" class="block text-sm font-semibold text-brand mb-2">Besked (valgfri)</label>
        <textarea
          id="message"
          name="message"
          rows="4"
          placeholder="Fortael os om dit fokus, branche, eller saerlige spoergsmaal..."
          class="w-full px-4 py-3 border border-gray-300 text-brand placeholder-gray-400 focus:outline-none focus:border-accent transition-colors resize-vertical"
        ></textarea>
      </div>

      <div class="flex items-start gap-3">
        <input type="checkbox" id="gdpr" name="gdpr" required aria-required="true" class="mt-1" />
        <label for="gdpr" class="text-sm text-gray-500">
          Jeg accepterer at SitedokAI bruger mine data til at levere rapporten og kontakte mig om ordren.
          Se vores <a href="/privatlivspolitik" class="underline hover:text-brand">privatlivspolitik</a>.
        </label>
      </div>

      <button
        type="submit"
        class="w-full bg-accent text-brand py-4 px-8 font-bold text-lg hover:bg-accent-light transition-colors"
      >
        Bestil rapport — 2.495 kr
      </button>
    </form>
  </div>
</section>


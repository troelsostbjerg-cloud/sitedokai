    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />',
    accent: true,
  },
  {
    title: 'Perplexity Synlighed',
    desc: 'Citerer Perplexity dig som kilde når brugere søger på dine kerneområder?',
    source: 'Perplexity API',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />',
    accent: true,
  },
  {
    title: 'Google AI Overviews',
    desc: 'Vises du i Googles AI-genererede svar øverst i søgeresultaterne?',
    source: 'Google API',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />',
    accent: true,
  },
  {
    title: 'Claude Synlighed',
    desc: 'Nævner Anthropics Claude din virksomhed i relevante branchesøgninger?',
    source: 'Claude API',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />',
    accent: true,

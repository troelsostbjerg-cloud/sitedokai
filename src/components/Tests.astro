---

<section id="tests" class="bg-gray-50 border-b border-gray-200">
  <div class="max-w-5xl mx-auto px-6 py-20 md:py-28">
    <!-- AI Visibility tests -->
    <div class="mb-20">
      <div class="inline-flex items-center gap-2 text-accent text-xs font-semibold uppercase tracking-wider mb-4">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>
        Primær analyse — 80% af auditen
      </div>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-brand tracking-tight mb-4">
        AI-synlighed: Kan AI finde dig?
      </h2>
      <p class="text-lg text-gray-500 max-w-2xl mb-10">
        Vi tester systematisk din synlighed på tværs af 4 AI-platforme med branchespecifikke søgninger — så du ved præcis hvor du står, og hvad der skal til for at dukke op.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {aiTests.map((test) => (
          <div
            class="relative bg-white rounded-xl border border-gray-200 p-6 md:p-8 hover:shadow-md transition-shadow overflow-hidden"
          >
            <div class="absolute top-0 left-0 w-1 h-full rounded-l-xl" style={`background: ${test.color}`}></div>
            <div class="flex items-start gap-4">
              <div
                class="w-11 h-11 flex items-center justify-center rounded-lg flex-shrink-0"
                style={`background: ${test.bg}; border: 1px solid ${test.border}`}
              >
                <svg class="w-5 h-5" fill="none" stroke={test.color} viewBox="0 0 24 24">
                  <Fragment set:html={test.icon} />
                </svg>
              </div>
              <div class="min-w-0">
                <h3 class="font-display text-base font-bold text-brand mb-1">{test.title}</h3>
                <p class="text-sm text-gray-500 leading-relaxed mb-2">{test.desc}</p>
                <p class="text-xs font-medium" style={`color: ${test.color}`}>{test.source}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Technical tests -->
    <div>
      <div class="inline-flex items-center gap-2 text-gray-400 text-xs font-semibold uppercase tracking-wider mb-4">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
        Teknisk sundhed — 20% af auditen
      </div>
      <h3 class="font-display text-2xl font-bold text-brand tracking-tight mb-6">
        Website performance og sikkerhed
      </h3>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
        {techTests.map((test) => {
          const C = 100.53; // circumference of r=16 circle
          const dash = (test.score / 100) * C;
          const gap = C - dash;
          return (
            <div class="group bg-white border border-gray-200 rounded-xl p-5 hover:shadow-md hover:border-accent/30 transition-all duration-200 flex flex-col gap-4">
              <!-- Icon + title -->
              <div class="flex items-center gap-3">
                <div class="w-9 h-9 flex items-center justify-center rounded-lg bg-accent/8 flex-shrink-0">
                  <svg class="w-4.5 h-4.5" fill="none" stroke="#0e7490" viewBox="0 0 24 24">
                    <Fragment set:html={test.icon} />
                  </svg>
                </div>
                <div>
                  <div class="text-sm font-bold text-brand leading-tight">{test.title}</div>
                  <div class="text-xs text-gray-400 leading-tight mt-0.5">{test.desc}</div>
                </div>
              </div>

              <!-- Score ring + number -->
              <div class="flex items-center gap-3">
                <div class="relative flex-shrink-0">
                  <svg width="44" height="44" viewBox="0 0 44 44" class="rotate-[-90deg]">
                    <!-- Track -->
                    <circle cx="22" cy="22" r="16" fill="none" stroke="#e5e7eb" stroke-width="3.5" />
                    <!-- Progress -->
                    <circle
                      cx="22" cy="22" r="16"
                      fill="none"
                      stroke={test.ringColor}
                      stroke-width="3.5"
                      stroke-linecap="round"
                      stroke-dasharray={`${dash} ${gap}`}
                    />
                  </svg>
                  <span class="absolute inset-0 flex items-center justify-center text-[10px] font-bold" style={`color: ${test.ringColor}`}>
                    {test.score}
                  </span>
                </div>
                <div class="min-w-0">
                  <div class="text-xs font-semibold px-2 py-0.5 rounded-full inline-block" style={`color: ${test.gradeColor}; background: ${test.gradeBg}`}>
                    {test.grade}
                  </div>
                  <!-- Progress bar -->
                  <div class="mt-2 h-1 w-full bg-gray-100 rounded-full overflow-hidden">
                    <div class="h-full rounded-full transition-all" style={`width: ${test.score}%; background: ${test.ringColor}`}></div>
                  </div>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </div>
</section>

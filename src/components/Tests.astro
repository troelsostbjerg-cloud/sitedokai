  {
    title: 'ChatGPT',
    desc: 'Bliver din virksomhed anbefalet, når kunder spørger ChatGPT om dit fagområde?',
    source: 'Prompttests og svaranalyse',
    color: '#10a37f',
    bg: 'rgba(16,163,127,0.08)',
    border: 'rgba(16,163,127,0.2)',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />',
  },
  {
    title: 'Gemini',
    desc: 'Anbefaler Googles Gemini din virksomhed i relevante branchesøgninger?',
    source: 'Prompttests og kildekontrol',
    color: '#8a64ff',
    bg: 'rgba(138,100,255,0.08)',
    border: 'rgba(138,100,255,0.2)',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />',
  },
  {
    title: 'Google AI Overviews',

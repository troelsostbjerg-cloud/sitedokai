const techTests = [
  {
    title: 'Desktop Performance',
    desc: 'Indlæsningshastighed, responsivitet og visuel stabilitet.',
    source: 'Google PageSpeed API',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />',
  },
  {
    title: 'Mobile Performance',
    desc: 'Test på smartphones. Afgørende for moderne brugeroplevelse.',
    source: 'Chrome UX Report',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />',
  },
  {
    title: 'SSL og Sikkerhed',
    desc: 'HTTPS-status, security headers og beskyttelse mod angreb.',
    source: 'SSL Labs API',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />',
  },
  {
    title: 'SEO og Tilgængelighed',
    desc: 'Meta-tags, struktur, WCAG 2.1 og søgemaskineoptimering.',
    source: 'axe DevTools + HTML Analyse',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />',
  },
  {
    title: 'Core Web Vitals',
    desc: 'Googles vigtigste metrics for brugeroplevelse og rangering.',
    source: 'Chrome UX Report',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />',
  },
];
---

<section id="tests" class="bg-gray-50 border-b border-gray-200">
  <div class="max-w-5xl mx-auto px-6 py-20 md:py-28">
    <!-- AI Visibility tests (primary) -->
    <div class="mb-16">
      <div class="inline-flex items-center gap-2 text-accent text-xs font-semibold uppercase tracking-wider mb-4">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>
        Primær analyse: 80% af rapporten
      </div>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-brand tracking-tight mb-4">
        AI-synlighed: Kan AI finde dig?
      </h2>
      <p class="text-lg text-gray-500 max-w-2xl mb-10">
        Ingen kan selv tjekke deres AI-synlighed. Vi tester din virksomhed på tværs af 5 AI-platforme med branchespecifikke søgninger.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-accent/20">
        {aiTests.map((test) => (
          <div class="bg-white p-6 md:p-8">
            <div class="w-10 h-10 flex items-center justify-center mb-4 text-accent">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <Fragment set:html={test.icon} />
              </svg>
            </div>
            <h3 class="font-display text-base font-bold text-brand mb-2">{test.title}</h3>
            <p class="text-sm text-gray-500 leading-relaxed mb-3">{test.desc}</p>
            <p class="text-xs text-accent font-medium">{test.source}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Technical tests (secondary) -->
    <div>
      <div class="inline-flex items-center gap-2 text-gray-400 text-xs font-semibold uppercase tracking-wider mb-4">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
        Teknisk sundhed: 20% af rapporten
      </div>
      <h3 class="font-display text-2xl font-bold text-brand tracking-tight mb-8">
        Website performance og sikkerhed
      </h3>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-gray-200">
        {techTests.map((test) => (
          <div class="bg-white p-6 md:p-8">
            <div class="w-10 h-10 flex items-center justify-center mb-4 text-gray-400">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <Fragment set:html={test.icon} />
              </svg>
            </div>
            <h3 class="text-base font-bold text-brand mb-2">{test.title}</h3>
            <p class="text-sm text-gray-500 leading-relaxed mb-3">{test.desc}</p>
            <p class="text-xs text-gray-400 italic">Kilde: {test.source}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<Layout title="Kontakt - SitedokAI" description="Book en gennemgang med Troels eller skriv til os direkte. Vi svarer inden for 24 timer.">
  <Nav />
  <main>
    <!-- Hero -->
    <section class="bg-white border-b border-gray-200">
      <div class="max-w-5xl mx-auto px-6 py-20 md:py-28">
        <div class="max-w-2xl">
          <h1 class="font-display text-4xl md:text-5xl font-extrabold text-brand tracking-tight mb-4">
            Lad os tale om din hjemmeside
          </h1>
          <p class="text-lg text-gray-500">
            Book 30 minutter med Troels. Vi gennemgår din rapport og laver en plan, der virker.
          </p>
        </div>
      </div>
    </section>

    <!-- Contact Form + Info -->
    <section class="bg-gray-50">
      <div class="max-w-5xl mx-auto px-6 py-20 md:py-28">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16">
          <!-- Form -->
          <div>
            <h2 class="font-display text-2xl font-bold text-brand mb-8">Skriv til os</h2>
            <form id="contactForm" class="space-y-6">
              <div>
                <label for="name" class="block text-sm font-semibold text-brand mb-2">Dit navn *</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  aria-required="true"
                  class="w-full px-4 py-3 border border-gray-300 bg-white text-brand placeholder-gray-400 focus:outline-none focus:border-accent transition-colors"
                />
              </div>

              <div>
                <label for="email" class="block text-sm font-semibold text-brand mb-2">Email-adresse *</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  aria-required="true"
                  class="w-full px-4 py-3 border border-gray-300 bg-white text-brand placeholder-gray-400 focus:outline-none focus:border-accent transition-colors"
                />
              </div>

              <div>
                <label for="website" class="block text-sm font-semibold text-brand mb-2">Website URL</label>
                <input
                  type="url"
                  id="website"
                  name="website"
                  placeholder="https://www.example.dk"
                  class="w-full px-4 py-3 border border-gray-300 bg-white text-brand placeholder-gray-400 focus:outline-none focus:border-accent transition-colors"
                />
              </div>

              <div>
                <label for="message" class="block text-sm font-semibold text-brand mb-2">Besked *</label>
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  required
                  aria-required="true"
                  placeholder="Hvad kan vi hjælpe med?"
                  class="w-full px-4 py-3 border border-gray-300 bg-white text-brand placeholder-gray-400 focus:outline-none focus:border-accent transition-colors resize-vertical"
                ></textarea>
              </div>

              <div class="flex items-start gap-3">
                <input type="checkbox" id="gdpr" name="gdpr" required aria-required="true" class="mt-1" />
                <label for="gdpr" class="text-sm text-gray-500">
                  Jeg accepterer at SitedokAI kontakter mig og gemmer mine data jf. GDPR.
                </label>
              </div>

              <div id="formMessage" class="hidden"></div>

              <button
                type="submit"
                class="w-full bg-accent text-brand py-4 px-8 font-bold text-lg hover:bg-accent-light transition-colors"
              >
                Send besked
              </button>
            </form>
          </div>

          <!-- Info -->
          <div class="space-y-10">
            <div>
              <h2 class="font-display text-2xl font-bold text-brand mb-6">Eller kontakt os direkte</h2>
              <div class="space-y-4">
                <div class="bg-white border border-gray-200 p-6">
                  <div class="text-sm font-bold text-brand mb-1">Email</div>
                  <a href="mailto:kontakt@sitedokai.com" class="text-accent hover:text-accent-dim transition-colors">
                    kontakt@sitedokai.com
                  </a>
                </div>
                <div class="bg-white border border-gray-200 p-6">
                  <div class="text-sm font-bold text-brand mb-1">Svartid</div>
                  <div class="text-gray-500">Inden for 24 timer på hverdage</div>
                </div>
                <div class="bg-white border border-gray-200 p-6">
                  <div class="text-sm font-bold text-brand mb-1">Lokation</div>
                  <div class="text-gray-500">Danmark</div>
                </div>
              </div>
            </div>

            <div class="bg-brand text-white p-8">
              <h3 class="font-display text-xl font-bold mb-3">Vil du hellere starte med en gratis rapport?</h3>
              <p class="text-white/60 mb-6 text-sm leading-relaxed">
                Indsend din URL og få en AI-synlighedsrapport inden for 24 timer. Ingen forpligtelse.
              </p>
              <a href="/gratis-rapport" class="inline-block bg-amber-400 text-brand py-3 px-8 font-bold text-sm hover:bg-amber-300 transition-colors">
                Bestil gratis rapport
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  const form = document.getElementById('contactForm') as HTMLFormElement;
  const formMessage = document.getElementById('formMessage') as HTMLDivElement;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const email = formData.get('email') as string;

    formMessage.className = 'p-4 bg-green-50 text-green-800 border border-green-200 text-sm';
    formMessage.textContent = `Tak! Vi har modtaget din besked og vender tilbage inden 24 timer på: ${email}`;

    form.reset();
    setTimeout(() => {
      formMessage.className = 'hidden';
      formMessage.textContent = '';
    }, 5000);
  });
</script>

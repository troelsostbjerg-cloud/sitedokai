---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<Layout title="Bestil rapport - SitedokAI" description="Bestil en AI-synlighedsrapport fra SitedokAI for 2.495 kr. Leveret som PDF inden for 48 timer på hverdage.">
  <Nav />
  <main>
    <section class="bg-white border-b border-gray-200">
      <div class="max-w-5xl mx-auto px-6 py-20 md:py-28">
        <div class="max-w-2xl">
          <h1 class="font-display text-4xl md:text-5xl font-extrabold text-brand tracking-tight mb-4">
            Bestil din rapport
          </h1>
          <p class="text-lg text-gray-500">
            SiteDokAI er et enkelt produkt: en AI-synlighedsrapport til 2.495 kr. Ingen møder, ingen abonnement, ingen efterfølgende konsulentforløb.
          </p>
        </div>
      </div>
    </section>

    <section class="bg-gray-50">
      <div class="max-w-5xl mx-auto px-6 py-20 md:py-28">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16">
          <div>
            <h2 class="font-display text-2xl font-bold text-brand mb-8">Indsend din bestilling</h2>
            <form action="https://formsubmit.co/troelsostbjerg@gmail.com" method="POST" class="space-y-6">
              <input type="hidden" name="_subject" value="Ny bestilling - SitedokAI rapport" />
              <input type="hidden" name="_captcha" value="false" />
              <input type="hidden" name="_template" value="table" />

              <div>
                <label for="name" class="block text-sm font-semibold text-brand mb-2">Dit navn *</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  aria-required="true"
                  class="w-full px-4 py-3 border border-gray-300 bg-white text-brand placeholder-gray-400 focus:outline-none focus:border-accent transition-colors"
                />
              </div>

              <div>
                <label for="email" class="block text-sm font-semibold text-brand mb-2">Email-adresse *</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  aria-required="true"
                  class="w-full px-4 py-3 border border-gray-300 bg-white text-brand placeholder-gray-400 focus:outline-none focus:border-accent transition-colors"
                />
              </div>

              <div>
                <label for="website" class="block text-sm font-semibold text-brand mb-2">Website URL *</label>
                <input
                  type="text"
                  inputmode="url"
                  autocomplete="url"
                  autocapitalize="none"
                  spellcheck="false"
                  id="website"
                  name="website"
                  placeholder="www.example.dk"
                  required
                  aria-required="true"
                  class="w-full px-4 py-3 border border-gray-300 bg-white text-brand placeholder-gray-400 focus:outline-none focus:border-accent transition-colors"
                />
              </div>

              <div>
                <label for="message" class="block text-sm font-semibold text-brand mb-2">Noter (valgfri)</label>
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  placeholder="Branche, konkurrenter eller særlige sider vi skal være opmærksomme på"
                  class="w-full px-4 py-3 border border-gray-300 bg-white text-brand placeholder-gray-400 focus:outline-none focus:border-accent transition-colors resize-vertical"
                ></textarea>
              </div>

              <div class="flex items-start gap-3">
                <input type="checkbox" id="gdpr" name="gdpr" required aria-required="true" class="mt-1" />
                <label for="gdpr" class="text-sm text-gray-500">
                  Jeg accepterer at SitedokAI bruger mine data til at levere rapporten og kontakte mig om ordren.
                </label>
              </div>

              <button
                type="submit"
                class="w-full bg-accent text-brand py-4 px-8 font-bold text-lg hover:bg-accent-light transition-colors"
              >
                Bestil rapport — 2.495 kr
              </button>
            </form>
          </div>

          <div class="space-y-10">
            <div>
              <h2 class="font-display text-2xl font-bold text-brand mb-6">Det får du</h2>
              <div class="space-y-4">
                <div class="bg-white border border-gray-200 p-6">
                  <div class="text-sm font-bold text-brand mb-1">Leverance</div>
                  <div class="text-gray-500">Færdig PDF-rapport med AI-synlighed, tekniske fund og prioriterede forbedringer</div>
                </div>
                <div class="bg-white border border-gray-200 p-6">
                  <div class="text-sm font-bold text-brand mb-1">Leveringstid</div>
                  <div class="text-gray-500">Normalt inden for 48 timer på hverdage</div>
                </div>
                <div class="bg-white border border-gray-200 p-6">
                  <div class="text-sm font-bold text-brand mb-1">Pris</div>
                  <div class="text-gray-500">2.495 kr som engangsbeløb</div>
                </div>
              </div>
            </div>

            <div class="bg-brand text-white p-8">
              <h3 class="font-display text-xl font-bold mb-3">Direkte og simpelt</h3>
              <p class="text-white/60 mb-0 text-sm leading-relaxed">
                Du bestiller rapporten. Vi laver rapporten. Du får rapporten. Det er hele modellen.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const trustBullets = [
  'Ingen abonnement eller binding',
  'Kortbetaling nu via Stripe',
  'Privat link + adgangskode',
];

const checkoutAction = 'https://sitedokai-checkout.pages.dev/api/checkout';
const siteOrigin = 'https://sitedokai.com';

const steps = [
  'Udfyld firmanavn, kontaktperson, email og website.',
  'Du går videre til sikker betaling på 2.495 kr.',
  'Når bestilling og betaling er gennemført, starter vi gennemgangen samme hverdag eller næste hverdag.',
  'Stripe sender kvittering/faktura for betalingen, og du modtager derefter en mail med et privat link og en adgangskode til dit firmas Client Room inden for 48 timer på hverdage. PDF følger med som eksport.',
];

const included = [
  'AI-synlighed på 4 platforme: ChatGPT, Gemini, Google AI og Claude',
  'Gennemgang af 1 website og op til 5 nøglesider',
  'Client Room leveret som privat link + adgangskode, med teknisk baseline, konkurrentbillede og næste skridt',
];
---

<Layout title="Bestil AI-audit - SitedokAI" description="Bestil AI-auditen fra SitedokAI for 2.495 kr. Betal med kort via Stripe, modtag kvittering/faktura bagefter, og få levering via privat link og adgangskode til dit firmas Client Room inden for 48 timer på hverdage.">
  <Nav />
  <main>
    <section class="bg-white border-b border-gray-200">
      <div class="max-w-5xl mx-auto px-6 py-20 md:py-28">
        <div class="max-w-3xl">
          <div class="text-sm font-semibold uppercase tracking-wider text-accent mb-4">Bestil auditen</div>
          <h1 class="font-display text-4xl md:text-5xl font-extrabold text-brand tracking-tight mb-4">
            Bestil AI-audit hvis det virker som det rigtige næste skridt
          </h1>
          <p class="text-lg text-gray-500 leading-relaxed">
            Udfyld formularen, betal sikkert med kort via Stripe, og modtag derefter både Stripe-kvittering/faktura og en mail med et privat link og en adgangskode til dit firmas Client Room. Her får I status, fund og prioriterede næste skridt samlet i samme leverance.
          </p>
        </div>
      </div>
    </section>

    <section class="bg-gray-50">
      <div class="max-w-5xl mx-auto px-6 py-20 md:py-28">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16 items-start">
          <div class="bg-white border border-gray-200 rounded-2xl p-6 md:p-8">
            <h2 class="font-display text-2xl font-bold text-brand mb-8">Indsend din bestilling</h2>
            <form action={checkoutAction} method="POST" class="space-y-6">
              <input type="hidden" name="source_page" value="kontakt_page" />
              <input type="hidden" name="return_path" value="/kontakt" />
              <input type="hidden" name="site_origin" value={siteOrigin} />

              <div>
                <label for="company_name" class="block text-sm font-semibold text-brand mb-2">Firmanavn *</label>
                <input type="text" id="company_name" name="company_name" required aria-required="true" autocomplete="organization" class="w-full px-4 py-3 border border-gray-300 bg-white text-brand placeholder-gray-400 focus:outline-none focus:border-accent transition-colors" />
              </div>

              <div>
                <label for="name" class="block text-sm font-semibold text-brand mb-2">Kontaktperson *</label>
                <input type="text" id="name" name="name" required aria-required="true" autocomplete="name" class="w-full px-4 py-3 border border-gray-300 bg-white text-brand placeholder-gray-400 focus:outline-none focus:border-accent transition-colors" />
              </div>

              <div>
                <label for="email" class="block text-sm font-semibold text-brand mb-2">Email-adresse *</label>
                <input type="email" id="email" name="email" required aria-required="true" autocomplete="email" class="w-full px-4 py-3 border border-gray-300 bg-white text-brand placeholder-gray-400 focus:outline-none focus:border-accent transition-colors" />
              </div>

              <div>
                <label for="website" class="block text-sm font-semibold text-brand mb-2">Website URL *</label>
                <input type="text" inputmode="url" autocomplete="url" autocapitalize="none" spellcheck="false" id="website" name="website" placeholder="www.example.dk" required aria-required="true" class="w-full px-4 py-3 border border-gray-300 bg-white text-brand placeholder-gray-400 focus:outline-none focus:border-accent transition-colors" />
              </div>

              <div>
                <label for="message" class="block text-sm font-semibold text-brand mb-2">Noter (valgfri, 30 sek.)</label>
                <p class="text-sm text-gray-500 mb-3">
                  Skriv kun hvis relevant: jeres vigtigste ydelse, primære område og evt. 1-3 sider vi skal fokusere ekstra på. Konkurrenter finder vi som regel selv.
                </p>
                <textarea id="message" name="message" rows="5" placeholder="Fx: Vi er tømrer i Køge og Roskilde. Fokusér især på totalentreprise og energirenovering. Kig gerne ekstra på /services/totalentreprise og /kontakt." class="w-full px-4 py-3 border border-gray-300 bg-white text-brand placeholder-gray-400 focus:outline-none focus:border-accent transition-colors resize-vertical"></textarea>
              </div>

              <div class="flex items-start gap-3">
                <input type="checkbox" id="gdpr" name="gdpr" required aria-required="true" class="mt-1" />
                <label for="gdpr" class="text-sm text-gray-500">
                  Jeg accepterer at SitedokAI bruger mine data til at levere auditen og kontakte mig om ordren.
                </label>
              </div>

              <button type="submit" class="w-full bg-brand text-white py-4 px-8 font-bold text-lg hover:bg-brand-light transition-colors rounded-md">
                Gå til sikker betaling på 2.495 kr
              </button>

              <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                {trustBullets.map((item) => (
                  <div class="bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 text-sm text-gray-600 text-center">
                    {item}
                  </div>
                ))}
              </div>

              <p class="text-xs text-gray-500 leading-relaxed">
                Når du klikker på knappen, opretter vi din Stripe-checkout med firmanavn, website og noter, så betaling, faktura og ordregrundlag hænger sammen bagefter.
              </p>
            </form>
          </div>

          <div class="space-y-6">
            <div class="bg-[#f3ebdd] text-brand rounded-2xl p-6 md:p-8 border border-[#e1d2bc]">
              <h2 class="font-display text-2xl font-bold mb-6">Hvad sker der efter bestilling?</h2>
              <ol class="space-y-4">
                {steps.map((step, index) => (
                  <li class="flex items-start gap-4 text-sm text-brand/72 leading-relaxed">
                    <span class="w-8 h-8 rounded-full bg-white text-brand font-bold flex items-center justify-center flex-shrink-0 border border-[#e1d2bc]">{index + 1}</span>
                    <span>{step}</span>
                  </li>
                ))}
              </ol>
            </div>

            <div class="bg-white border border-gray-200 rounded-2xl p-6 md:p-8">
              <h3 class="font-display text-xl font-bold text-brand mb-4">Det får du</h3>
              <ul class="space-y-3 text-sm text-gray-600 mb-6">
                {included.map((item) => (
                  <li class="flex items-start gap-3">
                    <span class="w-2 h-2 rounded-full bg-accent mt-2 flex-shrink-0"></span>
                    <span>{item}</span>
                  </li>
                ))}
                <li class="flex items-start gap-3">
                  <span class="w-2 h-2 rounded-full bg-accent mt-2 flex-shrink-0"></span>
                  <span>Betalt Stripe-kvittering/faktura sendt automatisk efter kortbetalingen.</span>
                </li>
              </ul>
              <a href="/eksempel" class="inline-flex items-center gap-2 text-sm font-bold text-brand hover:text-accent transition-colors">
                Se demoen først
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

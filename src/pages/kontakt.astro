---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const checkoutAction = 'https://sitedokai-checkout.pages.dev/api/checkout';
const siteOrigin = 'https://sitedokai.com';

const auditIncluded = [
  'AI-synlighed på 4 platforme: ChatGPT, Gemini, Google AI og Claude',
  'Gennemgang af 1 website og op til 5 nøglesider',
  'Client Room med teknisk baseline, konkurrentbillede og næste skridt',
  'PDF som eksport til intern deling',
];

const auditFlow = [
  'Udfyld firmanavn, kontaktperson, email og website.',
  'Du går videre til sikker betaling på 2.495 kr via Stripe.',
  'Vi starter gennemgangen samme hverdag eller næste hverdag.',
  'Du modtager derefter en mail med et privat link og en adgangskode til Client Room inden for 48 timer på hverdage.',
];

const discoveryFlow = [
  'Skriv kort hvad problemet handler om: synlighed, dokumentation, workflow eller et værktøj der mangler.',
  'Send gerne 2-3 links eller eksempler hvis det hjælper med at afgrænse casen.',
  'Vi svarer med næste rigtige format: sprint, room, build eller partnerforløb.',
];

const discoveryPrompts = [
  '“Vi drukner i dokumentation og mangler et sted at samle status.”',
  '“Vores website forklarer os dårligt, og AI nævner konkurrenter mere end os.”',
  '“Vi bruger stadig mail og Excel til noget der nok burde være et lille system.”',
];
---

<Layout
  title="Kontakt og startspor | SiteDok"
  description="Start med AI Audit eller kontakt SiteDok om sprint, room, workflow eller dashboard. AI Audit kan bestilles direkte for 2.495 kr."
>
  <Nav />
  <main id="main">
    <section class="border-b border-[#e6ddd1] bg-white">
      <div class="mx-auto max-w-6xl px-6 py-20 md:py-28">
        <div class="max-w-3xl">
          <p class="mb-4 text-sm font-semibold uppercase tracking-[0.18em] text-accent">Kontakt</p>
          <h1 class="font-display text-4xl font-extrabold tracking-tight text-brand md:text-6xl">
            Start med det rigtige spor.
          </h1>
          <p class="mt-6 text-lg leading-relaxed text-brand/70">
            Nogle virksomheder skal bare have en AI Audit. Andre ved allerede at problemet handler om dokumentation, workflow eller et lille værktøj.
            Derfor har vi gjort det nemt at starte begge steder.
          </p>
        </div>
      </div>
    </section>

    <section class="border-b border-[#e6ddd1] bg-[#f6f1e8]">
      <div class="mx-auto max-w-6xl px-6 py-20 md:py-28">
        <div class="grid gap-6 lg:grid-cols-2">
          <article id="audit" class="rounded-[2rem] border border-[#ddd1bf] bg-white p-8 shadow-[0_24px_60px_rgba(31,42,51,0.05)]">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent">Direkte bestilling</p>
            <div class="mt-4 flex items-start justify-between gap-4">
              <div>
                <h2 class="font-display text-3xl font-bold tracking-tight text-brand">AI Audit</h2>
                <p class="mt-3 text-base leading-relaxed text-brand/70">
                  Hvis I vil starte med et konkret produkt, kan I bestille AI Audit direkte her.
                </p>
              </div>
              <div class="rounded-full border border-[#d9ccb9] bg-[#faf6ef] px-4 py-2 text-xs font-semibold uppercase tracking-[0.12em] text-brand/70">
                2.495 kr
              </div>
            </div>

            <div class="mt-6 grid gap-3">
              {auditIncluded.map((item) => (
                <div class="rounded-[1rem] border border-[#e6ddd1] bg-[#fbf8f3] px-4 py-3 text-sm text-brand/70">{item}</div>
              ))}
            </div>

            <div class="mt-6 rounded-[1.4rem] border border-[#eadfce] bg-[#f7f0e4] p-5">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent">Efter bestilling</p>
              <ol class="mt-4 space-y-3">
                {auditFlow.map((item, index) => (
                  <li class="flex items-start gap-3 text-sm leading-relaxed text-brand/70">
                    <span class="flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full border border-[#d9ccb9] bg-white text-xs font-bold text-brand">{index + 1}</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ol>
            </div>
          </article>

          <article id="afklaring" class="rounded-[2rem] border border-[#ddd1bf] bg-[#1f2a33] p-8 text-white shadow-[0_24px_60px_rgba(31,42,51,0.12)]">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#d9b27a]">Afklaring</p>
            <h2 class="mt-4 font-display text-3xl font-bold tracking-tight">Room, sprint eller dashboard?</h2>
            <p class="mt-4 text-base leading-relaxed text-white/72">
              Hvis I allerede ved at problemet handler om dokumentation, drift eller et værktøj der mangler, så start her i stedet for at tvinge det ned i en AI Audit-bestilling.
            </p>

            <div class="mt-6 rounded-[1.4rem] border border-white/10 bg-white/6 p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.08)]">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#d9b27a]">Send os det her</p>
              <ol class="mt-4 space-y-3">
                {discoveryFlow.map((item, index) => (
                  <li class="flex items-start gap-3 text-sm leading-relaxed text-white/72">
                    <span class="flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full border border-white/10 bg-black/10 text-xs font-bold text-white">{index + 1}</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ol>
            </div>

            <div class="mt-6 grid gap-3">
              {discoveryPrompts.map((item) => (
                <div class="rounded-[1rem] border border-white/10 bg-black/10 px-4 py-3 text-sm text-white/72">{item}</div>
              ))}
            </div>

            <a href="mailto:info@sitedokai.com?subject=Afklaring%20med%20SiteDok" class="mt-6 inline-flex items-center justify-center rounded-full bg-[#d9b27a] px-6 py-3 text-sm font-bold text-brand transition-colors hover:bg-[#e4c08e]">
              Skriv til info@sitedokai.com
            </a>
          </article>
        </div>
      </div>
    </section>

    <section class="border-b border-[#e6ddd1] bg-white">
      <div class="mx-auto max-w-6xl px-6 py-20 md:py-28">
        <div class="grid gap-12 lg:grid-cols-[1.08fr_0.92fr]">
          <div class="rounded-[2rem] border border-[#e6ddd1] bg-[#fbf8f3] p-8 shadow-[0_18px_44px_rgba(31,42,51,0.03)]">
            <h2 class="font-display text-3xl font-bold tracking-tight text-brand">Bestil AI Audit</h2>
            <p class="mt-4 text-base leading-relaxed text-brand/70">
              Formularen her er kun til AI Audit-sporet. Hvis I vil tale room, sprint eller build, så brug mailsporet ovenfor.
            </p>

            <form action={checkoutAction} method="POST" class="mt-8 space-y-6">
              <input type="hidden" name="source_page" value="kontakt_page" />
              <input type="hidden" name="return_path" value="/kontakt#audit" />
              <input type="hidden" name="site_origin" value={siteOrigin} />

              <div>
                <label for="company_name" class="mb-2 block text-sm font-semibold text-brand">Firmanavn *</label>
                <input type="text" id="company_name" name="company_name" required aria-required="true" autocomplete="organization" class="w-full rounded-[1rem] border border-[#d9cfbf] bg-white px-4 py-3 text-brand placeholder-gray-400 transition-colors focus:border-accent focus:outline-none" />
              </div>

              <div>
                <label for="name" class="mb-2 block text-sm font-semibold text-brand">Kontaktperson *</label>
                <input type="text" id="name" name="name" required aria-required="true" autocomplete="name" class="w-full rounded-[1rem] border border-[#d9cfbf] bg-white px-4 py-3 text-brand placeholder-gray-400 transition-colors focus:border-accent focus:outline-none" />
              </div>

              <div>
                <label for="email" class="mb-2 block text-sm font-semibold text-brand">Email-adresse *</label>
                <input type="email" id="email" name="email" required aria-required="true" autocomplete="email" class="w-full rounded-[1rem] border border-[#d9cfbf] bg-white px-4 py-3 text-brand placeholder-gray-400 transition-colors focus:border-accent focus:outline-none" />
              </div>

              <div>
                <label for="website" class="mb-2 block text-sm font-semibold text-brand">Website URL *</label>
                <input type="text" inputmode="url" autocomplete="url" autocapitalize="none" spellcheck="false" id="website" name="website" placeholder="www.example.dk" required aria-required="true" class="w-full rounded-[1rem] border border-[#d9cfbf] bg-white px-4 py-3 text-brand placeholder-gray-400 transition-colors focus:border-accent focus:outline-none" />
              </div>

              <div>
                <label for="message" class="mb-2 block text-sm font-semibold text-brand">Noter (valgfri)</label>
                <p class="mb-3 text-sm text-brand/60">
                  Skriv kun hvis relevant: vigtigste ydelse, primære område og 1-3 sider vi skal fokusere ekstra på.
                </p>
                <textarea id="message" name="message" rows="5" placeholder="Fx: Vi er tømrer i Køge og Roskilde. Fokusér især på totalentreprise og energirenovering." class="w-full resize-vertical rounded-[1rem] border border-[#d9cfbf] bg-white px-4 py-3 text-brand placeholder-gray-400 transition-colors focus:border-accent focus:outline-none"></textarea>
              </div>

              <div class="flex items-start gap-3">
                <input type="checkbox" id="gdpr" name="gdpr" required aria-required="true" class="mt-1" />
                <label for="gdpr" class="text-sm text-brand/60">
                  Jeg accepterer at SiteDok bruger mine data til at levere auditen og kontakte mig om ordren.
                </label>
              </div>

              <button type="submit" class="w-full rounded-full bg-brand px-8 py-4 text-lg font-bold text-white transition-colors hover:bg-brand-light">
                Gå til sikker betaling på 2.495 kr
              </button>

              <p class="text-xs leading-relaxed text-brand/60">
                Når du klikker på knappen, opretter vi din Stripe-checkout med firmanavn, website og noter, så betaling, faktura og ordregrundlag hænger sammen bagefter.
              </p>
            </form>
          </div>

          <div class="space-y-6">
            <div class="rounded-[2rem] border border-[#e6ddd1] bg-white p-8 shadow-[0_18px_44px_rgba(31,42,51,0.03)]">
              <h2 class="font-display text-3xl font-bold tracking-tight text-brand">Når AI Audit ikke er det rigtige</h2>
              <p class="mt-4 text-base leading-relaxed text-brand/70">
                Brug afklaringssporet hvis I allerede ved at behovet handler om et room, et workflow eller en lille app. Så undgår vi at presse en kompleks case ned i et forkert produktformat.
              </p>
            </div>

            <div class="rounded-[2rem] border border-[#d9ccb9] bg-[#f3eadb] p-8 shadow-[0_18px_44px_rgba(31,42,51,0.03)]">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent">Hurtig tommelfingerregel</p>
              <div class="mt-5 grid gap-3">
                <div class="rounded-[1rem] border border-[#ddd1bf] bg-white px-4 py-3 text-sm text-brand/70">Uklart problem eller usikker retning: start med AI Audit.</div>
                <div class="rounded-[1rem] border border-[#ddd1bf] bg-white px-4 py-3 text-sm text-brand/70">Rode i dokumentation og processer: start med room eller workflow-snak.</div>
                <div class="rounded-[1rem] border border-[#ddd1bf] bg-white px-4 py-3 text-sm text-brand/70">Behov for login, data og handlinger: start med build-afklaring.</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

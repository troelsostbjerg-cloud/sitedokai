---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const trustBullets = [
  'Ingen abonnement eller binding',
  'Sikker betaling via Stripe',
  'PDF leveres på mail',
];

const steps = [
  'Udfyld formularen med navn, email og website.',
  'Du går videre til sikker betaling på 2.495 kr.',
  'Når bestilling og betaling er gennemført, starter vi gennemgangen samme hverdag eller næste hverdag.',
  'Du modtager rapporten som PDF inden for 48 timer på hverdage.',
];

const included = [
  'AI-synlighed på 4 platforme',
  'Gennemgang af 1 website og op til 5 nøglesider',
  'Teknisk baseline og prioriterede anbefalinger',
];
---

<Layout title="Bestil AI-synlighedsrapport - SitedokAI" description="Bestil AI-synlighedsrapporten fra SitedokAI for 2.495 kr. Sikker betaling via Stripe og levering som PDF inden for 48 timer på hverdage.">
  <Nav />
  <main>
    <section class="bg-white border-b border-gray-200">
      <div class="max-w-5xl mx-auto px-6 py-20 md:py-28">
        <div class="max-w-3xl">
          <div class="text-sm font-semibold uppercase tracking-wider text-accent mb-4">Bestil rapporten</div>
          <h1 class="font-display text-4xl md:text-5xl font-extrabold text-brand tracking-tight mb-4">
            Bestil AI-synlighedsrapport for 2.495 kr
          </h1>
          <p class="text-lg text-gray-500 leading-relaxed">
            Udfyld formularen, betal sikkert via Stripe, og modtag en dansk PDF med score, fund og prioriterede forbedringer. Hele flowet er gjort enkelt, tydeligt og uden abonnement.
          </p>
        </div>
      </div>
    </section>

    <section class="bg-gray-50">
      <div class="max-w-5xl mx-auto px-6 py-20 md:py-28">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16 items-start">
          <div class="bg-white border border-gray-200 rounded-2xl p-6 md:p-8">
            <h2 class="font-display text-2xl font-bold text-brand mb-8">Indsend din bestilling</h2>
            <form action="https://formsubmit.co/info@sitedokai.com" method="POST" class="space-y-6">
              <input type="hidden" name="_subject" value="Ny bestilling - SitedokAI rapport" />
              <input type="hidden" name="_captcha" value="false" />
              <input type="hidden" name="_template" value="table" />
              <input type="hidden" name="_next" value="https://buy.stripe.com/eVqdRaf6Wa7U0cZ2TE2sM00" />
              <input type="hidden" name="pakke" value="AI-synlighedsrapport 2.495 kr, 1 website, op til 5 nøglesider" />

              <div>
                <label for="name" class="block text-sm font-semibold text-brand mb-2">Dit navn *</label>
                <input type="text" id="name" name="name" required aria-required="true" class="w-full px-4 py-3 border border-gray-300 bg-white text-brand placeholder-gray-400 focus:outline-none focus:border-accent transition-colors" />
              </div>

              <div>
                <label for="email" class="block text-sm font-semibold text-brand mb-2">Email-adresse *</label>
                <input type="email" id="email" name="email" required aria-required="true" class="w-full px-4 py-3 border border-gray-300 bg-white text-brand placeholder-gray-400 focus:outline-none focus:border-accent transition-colors" />
              </div>

              <div>
                <label for="website" class="block text-sm font-semibold text-brand mb-2">Website URL *</label>
                <input type="text" inputmode="url" autocomplete="url" autocapitalize="none" spellcheck="false" id="website" name="website" placeholder="www.example.dk" required aria-required="true" class="w-full px-4 py-3 border border-gray-300 bg-white text-brand placeholder-gray-400 focus:outline-none focus:border-accent transition-colors" />
              </div>

              <div>
                <label for="message" class="block text-sm font-semibold text-brand mb-2">Noter (valgfri, 30 sek.)</label>
                <p class="text-sm text-gray-500 mb-3">
                  Skriv kun hvis relevant: jeres vigtigste ydelse, primære område og evt. 1-3 sider vi skal fokusere ekstra på. Konkurrenter finder vi som regel selv.
                </p>
                <textarea id="message" name="message" rows="5" placeholder="Fx: Vi er tømrer i Køge og Roskilde. Fokusér især på totalentreprise og energirenovering. Kig gerne ekstra på /services/totalentreprise og /kontakt." class="w-full px-4 py-3 border border-gray-300 bg-white text-brand placeholder-gray-400 focus:outline-none focus:border-accent transition-colors resize-vertical"></textarea>
              </div>

              <div class="flex items-start gap-3">
                <input type="checkbox" id="gdpr" name="gdpr" required aria-required="true" class="mt-1" />
                <label for="gdpr" class="text-sm text-gray-500">
                  Jeg accepterer at SitedokAI bruger mine data til at levere rapporten og kontakte mig om ordren.
                </label>
              </div>

              <button type="submit" class="w-full bg-amber-400 text-brand py-4 px-8 font-bold text-lg hover:bg-amber-300 transition-colors rounded-md">
                Bestil AI-synlighedsrapport for 2.495 kr
              </button>

              <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                {trustBullets.map((item) => (
                  <div class="bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 text-sm text-gray-600 text-center">
                    {item}
                  </div>
                ))}
              </div>

              <p class="text-xs text-gray-500 leading-relaxed">
                Når du klikker på knappen, sendes bestillingen til os og du videresendes til betaling via Stripe.
              </p>
            </form>
          </div>

          <div class="space-y-6">
            <div class="bg-brand text-white rounded-2xl p-6 md:p-8">
              <h2 class="font-display text-2xl font-bold mb-6">Hvad sker der efter bestilling?</h2>
              <ol class="space-y-4">
                {steps.map((step, index) => (
                  <li class="flex items-start gap-4 text-sm text-white/70 leading-relaxed">
                    <span class="w-8 h-8 rounded-full bg-white/10 text-white font-bold flex items-center justify-center flex-shrink-0">{index + 1}</span>
                    <span>{step}</span>
                  </li>
                ))}
              </ol>
            </div>

            <div class="bg-white border border-gray-200 rounded-2xl p-6 md:p-8">
              <h3 class="font-display text-xl font-bold text-brand mb-4">Det får du</h3>
              <ul class="space-y-3 text-sm text-gray-600 mb-6">
                {included.map((item) => (
                  <li class="flex items-start gap-3">
                    <span class="w-2 h-2 rounded-full bg-accent mt-2 flex-shrink-0"></span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
              <a href="/eksempel" class="inline-flex items-center gap-2 text-sm font-bold text-brand hover:text-accent transition-colors">
                Se eksempelrapporten først
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

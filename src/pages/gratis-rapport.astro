---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<Layout title="Gratis AI-synlighedsrapport - SitedokAI" description="Få din gratis AI-synlighedsrapport. Vi scanner din hjemmeside og viser dig præcis, hvad Google AI ser. Inden for 24 timer. Uden forpligtelse.">
  <Nav />
  <main>
    <!-- Hero -->
    <section class="bg-brand text-white">
      <div class="max-w-5xl mx-auto px-6 py-20 md:py-28">
        <div class="max-w-2xl mx-auto text-center">
          <h1 class="font-display text-4xl md:text-5xl font-extrabold tracking-tight mb-4">
            Få din gratis AI-synlighedsrapport
          </h1>
          <p class="text-lg text-white/60 mb-10">
            Vi scanner din hjemmeside og viser dig præcis, hvad Google AI ser. Inden for 24 timer. Uden forpligtelse.
          </p>

          <!-- Lead Capture Form -->
          <form id="leadForm" class="max-w-lg mx-auto space-y-4">
            <div>
              <input
                type="text"
                id="name"
                name="name"
                placeholder="Dit navn"
                required
                aria-required="true"
                aria-label="Dit navn"
                class="w-full px-4 py-3 bg-brand-light border border-white/20 text-white placeholder-white/40 focus:outline-none focus:border-accent transition-colors"
              />
            </div>
            <div>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="Din email-adresse"
                required
                aria-required="true"
                aria-label="Din email-adresse"
                class="w-full px-4 py-3 bg-brand-light border border-white/20 text-white placeholder-white/40 focus:outline-none focus:border-accent transition-colors"
              />
            </div>
            <div>
              <input
                type="url"
                id="website"
                name="website"
                placeholder="https://din-hjemmeside.dk"
                required
                aria-required="true"
                aria-label="Din hjemmesides URL"
                class="w-full px-4 py-3 bg-brand-light border border-white/20 text-white placeholder-white/40 focus:outline-none focus:border-accent transition-colors"
              />
            </div>

            <div class="flex items-start gap-3 text-left">
              <input type="checkbox" id="gdpr" name="gdpr" required aria-required="true" class="mt-1" />
              <label for="gdpr" class="text-sm text-white/50">
                Jeg accepterer at SitedokAI kontakter mig med rapporten og gemmer mine data jf. GDPR.
              </label>
            </div>

            <div id="formMessage" class="hidden"></div>

            <button
              type="submit"
              class="w-full bg-amber-400 text-brand py-4 px-8 font-bold text-lg hover:bg-amber-300 transition-colors"
            >
              Få din gratis rapport
            </button>
            <p class="text-sm text-white/30">Ingen kreditkort. Ingen forpligtelse. Rapport inden 24 timer.</p>
          </form>
        </div>
      </div>
    </section>

    <!-- What You Get -->
    <section class="bg-white border-b border-gray-200">
      <div class="max-w-5xl mx-auto px-6 py-20 md:py-28">
        <h2 class="font-display text-3xl md:text-4xl font-bold text-brand tracking-tight mb-12 text-center">
          Hvad du får
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="border border-gray-200 p-8">
            <div class="font-display text-xl font-bold text-brand mb-3">AI-synlighedsscore</div>
            <p class="text-gray-500 leading-relaxed">
              Fra 0 til 100. Sådan vurderer Google AI din hjemmeside sammenlignet med konkurrenterne.
            </p>
          </div>
          <div class="border border-gray-200 p-8">
            <div class="font-display text-xl font-bold text-brand mb-3">Performance-analyse</div>
            <p class="text-gray-500 leading-relaxed">
              Desktop og mobil. Vi måler, hvad der påvirker rangering og brugeroplevelse.
            </p>
          </div>
          <div class="border border-gray-200 p-8">
            <div class="font-display text-xl font-bold text-brand mb-3">De 5 vigtigste forbedringspunkter</div>
            <p class="text-gray-500 leading-relaxed">
              Ikke 100. Fem. Som du kan handle på denne uge.
            </p>
          </div>
          <div class="border border-gray-200 p-8">
            <div class="font-display text-xl font-bold text-brand mb-3">Sammenligning med branchegennemsnit</div>
            <p class="text-gray-500 leading-relaxed">
              Hvordan ligger du kontra dine konkurrenter på samme metriker.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- What We Don't Do -->
    <section class="bg-gray-50 border-b border-gray-200">
      <div class="max-w-3xl mx-auto px-6 py-20 md:py-28 text-center">
        <h2 class="font-display text-3xl md:text-4xl font-bold text-brand tracking-tight mb-6">
          Hvad vi IKKE gør
        </h2>
        <div class="space-y-4 text-gray-500 leading-relaxed">
          <p>Vi sender ingen spam. Vi deler ikke dine data. Vi binder dig ikke til noget.</p>
          <p>Rapport som standard PDF. Du ejer den helt. Vi bruger den til at forstå markedet bedre, ikke til at sælge til andre.</p>
        </div>
      </div>
    </section>

    <!-- Bottom -->
    <section class="bg-brand text-white">
      <div class="max-w-3xl mx-auto px-6 py-16 text-center">
        <p class="text-white/50">
          Bygget af Troels i Danmark. Ingen tricks, ingen falsk social proof, bare data.
        </p>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  const form = document.getElementById('leadForm') as HTMLFormElement;
  const formMessage = document.getElementById('formMessage') as HTMLDivElement;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const email = formData.get('email') as string;
    const website = formData.get('website') as string;

    formMessage.className = 'p-4 bg-green-900/30 text-green-300 border border-green-500/30 text-sm';
    formMessage.textContent = `Tak! Vi scanner ${website} og sender rapporten til ${email} inden 24 timer.`;

    form.reset();
    setTimeout(() => {
      formMessage.className = 'hidden';
      formMessage.textContent = '';
    }, 6000);
  });
</script>

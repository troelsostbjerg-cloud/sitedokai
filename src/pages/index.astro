---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import WhyNotDIY from '../components/WhyNotDIY.astro';
import DemoSlides from '../components/DemoSlides.astro';
import Pricing from '../components/Pricing.astro';
import MiniTest from '../components/MiniTest.astro';
import FAQ from '../components/FAQ.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const faqs = [
  {
    q: 'Hvad får jeg for 2.495 kr?',
    a: 'Du får en AI-audit af 1 website og op til 5 nøglesider, testet på 4 AI-platforme, leveret i et interaktivt Client Room med overblik, konkurrentbillede og prioriterede næste skridt. PDF følger med som eksport.',
  },
  {
    q: 'Hvad er ikke med?',
    a: 'Der er ingen implementering, intet abonnement og ingen tung platform. Du får diagnosen, de vigtigste næste skridt og en leverance der er let at dele internt.',
  },
  {
    q: 'Hvad sker der efter bestilling?',
    a: 'Du sender din URL og kontaktoplysninger, gennemfører betalingen via Stripe, og vi leverer et Client Room inden for 48 timer på hverdage.',
  },
  {
    q: 'Hvorfor skal jeg kende min AI-synlighed?',
    a: 'Stadig flere kunder bruger ChatGPT og lignende til at finde leverandører. Store virksomheder optimerer allerede aktivt for det. Hvis din virksomhed ikke dukker op, taber du kunder til konkurrenter der gør.',
  },
];

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://sitedokai.com/#organization',
      name: 'SitedokAI',
      url: 'https://sitedokai.com',
      logo: 'https://sitedokai.com/favicon.svg',
      email: 'info@sitedokai.com',
      contactPoint: [
        {
          '@type': 'ContactPoint',
          contactType: 'customer support',
          email: 'info@sitedokai.com',
          availableLanguage: ['da'],
        },
      ],
    },
    {
      '@type': 'WebSite',
      '@id': 'https://sitedokai.com/#website',
      url: 'https://sitedokai.com',
      name: 'SitedokAI',
      inLanguage: 'da-DK',
    },
    {
      '@type': 'Service',
      '@id': 'https://sitedokai.com/#service',
      name: 'SitedokAI AI-audit',
      serviceType: 'AI-audit med Client Room',
      provider: {
        '@id': 'https://sitedokai.com/#organization',
      },
      areaServed: {
        '@type': 'Country',
        name: 'Danmark',
      },
      description: 'AI-audit for 1 website og op til 5 nøglesider. Inkluderer vurdering på 4 AI-platforme, interaktivt Client Room og PDF-eksport.',
      offers: {
        '@type': 'Offer',
        price: '2495',
        priceCurrency: 'DKK',
        availability: 'https://schema.org/InStock',
        url: 'https://sitedokai.com/#contact',
      },
    },
    {
      '@type': 'FAQPage',
      '@id': 'https://sitedokai.com/#faq',
      mainEntity: faqs.map((faq) => ({
        '@type': 'Question',
        name: faq.q,
        acceptedAnswer: {
          '@type': 'Answer',
          text: faq.a,
        },
      })),
    },
  ],
};
---

<Layout
  title="SitedokAI: Er din hjemmeside synlig i AI?"
  description="Få en AI-audit fra SitedokAI. 2.495 kr for 1 website og op til 5 nøglesider på ChatGPT, Gemini, Codex og Google AI, leveret i et Client Room inden for 48 timer på hverdage."
  structuredData={structuredData}
>
  <Nav />
  <main id="main">
    <Hero />
    <MiniTest />
    <DemoSlides />
    <WhyNotDIY />
    <Pricing />
    <FAQ faqs={faqs} />
    <Contact />
  </main>
  <Footer />
</Layout>

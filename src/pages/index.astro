---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Tests from '../components/Tests.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Pricing from '../components/Pricing.astro';
import FAQ from '../components/FAQ.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const faqs = [
  {
    q: 'Hvad får jeg for 2.495 kr?',
    a: 'Du får et AI-synlighedstjek af 1 website og op til 5 nøglesider, vurderet på 4 AI-platforme, plus en detaljeret PDF med score, fund og prioriterede forbedringer.',
  },
  {
    q: 'Hvad er ikke med?',
    a: 'Der er ingen implementering, intet møde og ingen løbende rådgivning. Du får diagnosen og de vigtigste næste skridt.',
  },
  {
    q: 'Hvad sker der efter bestilling?',
    a: 'Du sender din URL og kontaktoplysninger. Vi bekræfter ordren på mail og leverer rapporten inden for 48 timer på hverdage.',
  },
  {
    q: 'Hvorfor skal jeg kende min AI-synlighed?',
    a: 'Stadig flere kunder bruger ChatGPT og lignende til at finde leverandører. Store virksomheder optimerer allerede aktivt for det. Hvis din virksomhed ikke dukker op, taber du kunder til konkurrenter der gør.',
  },
];

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://sitedokai.com/#organization',
      name: 'SitedokAI',
      url: 'https://sitedokai.com',
      logo: 'https://sitedokai.com/og-image.svg',
      email: 'info@sitedokai.com',
      contactPoint: [
        {
          '@type': 'ContactPoint',
          contactType: 'customer support',
          email: 'info@sitedokai.com',
          availableLanguage: ['da'],
        },
      ],
    },
    {
      '@type': 'WebSite',
      '@id': 'https://sitedokai.com/#website',
      url: 'https://sitedokai.com',
      name: 'SitedokAI',
      inLanguage: 'da-DK',
    },
    {
      '@type': 'Service',
      '@id': 'https://sitedokai.com/#service',
      name: 'SitedokAI AI-synlighedstjek',
      serviceType: 'AI-synlighedstjek',
      provider: {
        '@id': 'https://sitedokai.com/#organization',
      },
      areaServed: {
        '@type': 'Country',
        name: 'Danmark',
      },
      description: 'AI-synlighedstjek for 1 website og op til 5 nøglesider. Inkluderer vurdering på 4 AI-platforme og en kort PDF med 3 prioriterede forbedringer.',
      offers: {
        '@type': 'Offer',
        price: '2495',
        priceCurrency: 'DKK',
        availability: 'https://schema.org/InStock',
        url: 'https://sitedokai.com/#contact',
      },
    },
    {
      '@type': 'FAQPage',
      '@id': 'https://sitedokai.com/#faq',
      mainEntity: faqs.map((faq) => ({
        '@type': 'Question',
        name: faq.q,
        acceptedAnswer: {
          '@type': 'Answer',
          text: faq.a,
        },
      })),
    },
  ],
};
---

<Layout
  title="SitedokAI: Er din hjemmeside synlig i AI?"
  description="Få et AI-synlighedstjek fra SitedokAI. 2.495 kr for 1 website og op til 5 nøglesider på 4 AI-platforme, leveret som PDF inden for 48 timer på hverdage."
  structuredData={structuredData}
>
  <Nav />
  <main id="main">
    <Hero />

    <!-- Prominent eksempelrapport-sektion -->
    <section class="bg-white border-b border-gray-200">
      <div class="max-w-5xl mx-auto px-6 py-16 md:py-24">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
          <div>
            <p class="text-sm font-bold text-accent uppercase tracking-wider mb-3">Se hvad du får</p>
            <h2 class="font-display text-3xl md:text-4xl font-bold text-brand tracking-tight mb-4">
              Eksempel: AI-synlighedsrapport for Nordisk Køkken
            </h2>
            <p class="text-gray-500 leading-relaxed mb-4">
              Se en komplet rapport med AI-synlighedsscore, platformanalyse, teknisk audit og prioriterede forbedringer. Præcis hvad du får for din virksomhed.
            </p>
            <ul class="space-y-2 text-sm text-gray-500 mb-6">
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                AI-synlighed testet på ChatGPT, Gemini, Claude og Google AI
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                Konkurrent-benchmark med kilde-analyse
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                Teknisk audit: performance, SEO, sikkerhed, Core Web Vitals
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                Prioriterede forbedringer du kan handle på med det samme
              </li>
            </ul>
            <div class="flex flex-col sm:flex-row gap-3">
              <a href="/eksempel" class="inline-block bg-amber-400 text-brand px-6 py-3 font-bold hover:bg-amber-300 transition-colors">
                Se eksempelrapporten
              </a>
              <a href="/demo-rapport.html" class="inline-block border-2 border-brand text-brand px-6 py-3 font-bold hover:bg-brand hover:text-white transition-colors">
                Se den fulde PDF
              </a>
            </div>
          </div>
          <div class="bg-gray-50 border border-gray-200 rounded-2xl p-8 text-center">
            <p class="text-sm text-gray-400 uppercase tracking-wider font-semibold mb-3">Samlet score</p>
            <div class="inline-flex items-end gap-2 mb-3">
              <span class="font-display text-6xl font-extrabold text-red-500">32</span>
              <span class="text-xl text-gray-300 font-bold mb-2">/100</span>
            </div>
            <div class="inline-block bg-red-50 text-red-500 text-sm font-bold px-4 py-1.5 rounded-full mb-4">
              Lav synlighed
            </div>
            <div class="grid grid-cols-2 gap-3 mt-4">
              <div class="bg-white border border-gray-200 rounded-lg p-3">
                <div class="text-xs text-gray-400 mb-1">ChatGPT</div>
                <div class="text-sm font-bold text-red-500">Ikke synlig</div>
              </div>
              <div class="bg-white border border-gray-200 rounded-lg p-3">
                <div class="text-xs text-gray-400 mb-1">Google AI</div>
                <div class="text-sm font-bold text-red-500">Konkurrent dominerer</div>
              </div>
              <div class="bg-white border border-gray-200 rounded-lg p-3">
                <div class="text-xs text-gray-400 mb-1">Claude</div>
                <div class="text-sm font-bold text-yellow-500">Begrænset</div>
              </div>
              <div class="bg-white border border-gray-200 rounded-lg p-3">
                <div class="text-xs text-gray-400 mb-1">Gemini</div>
                <div class="text-sm font-bold text-yellow-500">Forældet info</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <Tests />
    <HowItWorks />
    <Pricing />
    <FAQ faqs={faqs} />
    <Contact />
  </main>
  <Footer />
</Layout>

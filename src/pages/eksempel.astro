---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ClientRoomPreview from '../components/ClientRoomPreview.astro';
import '../styles/global.css';
---

<Layout title="Client Room-demo — SitedokAI" description="Se en statisk demo af det Client Room, du modtager fra SitedokAI. Eksporten er sekundær; hovedoplevelsen er den interaktive kundeside.">
  <Nav />
  <main>
    <section class="bg-brand border-b border-white/10">
      <div class="max-w-5xl mx-auto px-6 pt-20 pb-16 md:pt-28 md:pb-20">
        <p class="text-sm text-accent-light font-semibold uppercase tracking-wider mb-3">Demo</p>
        <h1 class="font-display text-4xl md:text-5xl font-extrabold text-white mb-4">
          Se et rigtigt Client Room-eksempel
        </h1>
        <p class="text-white/60 text-lg max-w-3xl leading-relaxed">
          Her ser du den oplevelse, en kunde faktisk får. Fokus er ikke en rapportside eller et slideshow, men et enkelt overblik over hvor virksomheden står, hvad der holder den tilbage, og hvad teamet skal gøre først.
        </p>
        <p class="mt-6 text-sm text-white/35">
          Fiktiv virksomhed med eksempeldata. Din leverance bliver lavet med data fra dit eget website og dine vigtigste søgninger.
        </p>
      </div>
    </section>

    <ClientRoomPreview variant="full" />

    <section class="bg-white border-t border-gray-200">
      <div class="max-w-5xl mx-auto px-6 py-16 md:py-20">
        <div class="bg-brand rounded-[2rem] p-10 md:p-14 text-center shadow-[0_30px_80px_rgba(2,8,23,0.12)]">
          <p class="text-sm text-accent-light font-semibold uppercase tracking-wider mb-3">Næste skridt</p>
          <h2 class="font-display text-2xl md:text-3xl font-extrabold text-white mb-4">
            Vil du have et Client Room for din egen virksomhed?
          </h2>
          <p class="text-white/60 mb-8 max-w-2xl mx-auto leading-relaxed">
            Vi tester dit website på ChatGPT, Gemini, Google AI og Claude og leverer et Client Room med prioriterede næste skridt inden for 48 timer på hverdage.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/kontakt" class="inline-block bg-amber-400 text-brand px-8 py-3.5 font-bold text-lg hover:bg-amber-300 transition-colors rounded-full">
              Bestil AI-audit
            </a>
            <a href="/demo-rapport.html" class="inline-block border border-white/20 text-white/80 px-8 py-3.5 font-bold text-lg hover:bg-white/10 hover:text-white transition-colors rounded-full">
              Se eksporteksemplet
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const included = [
  'AI-synlighed testet på ChatGPT, Gemini, Google AI og Claude',
  'Gennemgang af 1 website og op til 5 nøglesider',
  'Teknisk baseline for performance, struktur, SEO og sikkerhed',
  'Interaktivt Client Room med status, konkurrentbillede og næste skridt',
  'PDF-eksport til intern deling',
  'Levering inden for 48 timer på hverdage',
  'Ingen abonnement, ingen binding og ingen skjulte tillæg',
];

const trustBullets = [
  'Sikker betaling via Stripe',
  'Client Room + PDF-eksport',
  'Privat link + adgangskode',
];

const orderFlow = [
  'Du udfylder formularen og går til betaling.',
  'Du gennemfører betalingen sikkert via Stripe.',
  'Vi tester website og nøglesider på tværs af AI-platforme og tekniske signaler.',
  'Du modtager en mail med et privat link og en adgangskode til dit firmas Client Room inden for 48 timer på hverdage. PDF følger med som eksport.',
];

const faqs = [
  {
    q: 'Hvad koster auditen?',
    a: 'Auditen koster 2.495 kr som engangsbeløb. Ingen abonnement. Ingen skjulte gebyrer.',
  },
  {
    q: 'Hvad får jeg konkret?',
    a: 'Du får et interaktivt Client Room med AI-status, teknisk gennemgang, konkurrentblik og prioriterede næste skridt. PDF følger med som eksport.',
  },
  {
    q: 'Skal jeg booke et møde eller en gennemgang?',
    a: 'Nej. Produktet er bevidst enkelt. Du bestiller auditen, vi leverer Client Room + PDF, og så kan du arbejde videre internt eller med din udvikler.',
  },
  {
    q: 'Hvor hurtigt leverer I?',
    a: 'Normalt inden for 48 timer på hverdage. Hvis din side er meget stor eller teknisk sær, siger vi det med det samme.',
  },
];
---

<Layout title="Priser - SitedokAI" description="AI-audit til 2.495 kr. Fast pris, sikker betaling og levering via privat link og adgangskode til dit firmas Client Room inden for 48 timer på hverdage.">
  <Nav />
  <main>
    <section class="bg-white border-b border-gray-200">
      <div class="max-w-5xl mx-auto px-6 py-20 md:py-28">
        <div class="max-w-3xl">
          <div class="text-sm font-semibold uppercase tracking-wider text-accent mb-4">Fast pris</div>
          <h1 class="font-display text-4xl md:text-5xl font-extrabold text-brand tracking-tight mb-4">
            AI-audit med Client Room til 2.495 kr
          </h1>
          <p class="text-lg text-gray-500 leading-relaxed">
            SitedokAI er ét produkt med én fast pris. Du bestiller auditen, betaler sikkert via Stripe og modtager en mail med et privat link og en adgangskode til dit firmas Client Room. PDF følger med som eksport.
          </p>
        </div>
      </div>
    </section>

    <section class="bg-[#f6f1e8] text-brand border-b border-[#e6ddd1]">
      <div class="max-w-5xl mx-auto px-6 py-20 md:py-28 grid grid-cols-1 lg:grid-cols-[1.05fr_0.95fr] gap-10 items-start">
        <div class="bg-white p-8 md:p-10 ring-1 ring-[#e0d6c8] rounded-2xl shadow-[0_24px_60px_rgba(31,42,51,0.05)]">
          <div class="text-sm font-bold text-brand/72 mb-3">SitedokAI Audit</div>
          <div class="font-display text-4xl md:text-5xl font-extrabold text-brand mb-1">2.495 kr</div>
          <div class="text-sm text-brand/60 mb-8">Engangskøb, levering inden for 48 timer på hverdage</div>

          <ul class="space-y-3 mb-8">
            {included.map((item) => (
              <li class="flex items-start gap-3 text-sm text-brand/72">
                <svg class="w-4 h-4 mt-0.5 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>

          <a href="/kontakt" class="block text-center py-4 px-6 font-bold text-lg bg-brand text-white hover:bg-brand-light transition-colors rounded-md mb-5">
            Bestil AI-audit for 2.495 kr
          </a>

          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
            {trustBullets.map((item) => (
              <div class="border border-[#e6ddd1] bg-[#faf6ef] rounded-xl px-4 py-3 text-sm text-brand/68 text-center">
                {item}
              </div>
            ))}
          </div>
        </div>

        <div class="space-y-6">
          <div class="bg-white border border-[#e6ddd1] rounded-2xl p-6 md:p-8">
            <div class="text-sm font-semibold uppercase tracking-wider text-accent mb-3">Hvad sker der efter bestilling?</div>
            <ol class="space-y-4">
              {orderFlow.map((item, index) => (
                <li class="flex items-start gap-4 text-sm text-brand/72 leading-relaxed">
                  <span class="w-8 h-8 rounded-full bg-[#faf6ef] text-brand font-bold flex items-center justify-center flex-shrink-0 border border-[#e6ddd1]">{index + 1}</span>
                  <span>{item}</span>
                </li>
              ))}
            </ol>
          </div>

          <div class="bg-white border border-[#e6ddd1] rounded-2xl p-6 md:p-8">
            <h2 class="font-display text-2xl font-bold text-brand mb-4">Vil du se leverancen først?</h2>
            <p class="text-brand/70 text-sm leading-relaxed mb-5">
              Se demoen og få en konkret fornemmelse af hvordan overblik, konkurrentbillede og næste skridt bliver præsenteret.
            </p>
            <a href="/eksempel" class="inline-flex items-center gap-2 text-sm font-bold text-brand hover:text-accent transition-colors">
              Se demoen
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-white border-b border-gray-200">
      <div class="max-w-3xl mx-auto px-6 py-20 md:py-28">
        <h2 class="font-display text-3xl md:text-4xl font-bold text-brand tracking-tight mb-12">
          Ofte stillede spørgsmål
        </h2>
        <div class="space-y-8">
          {faqs.map((faq) => (
            <div class="border-b border-gray-200 pb-8">
              <h3 class="font-display text-lg font-bold text-brand mb-3">{faq.q}</h3>
              <p class="text-gray-500 leading-relaxed">{faq.a}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-gray-50">
      <div class="max-w-5xl mx-auto px-6 py-20 md:py-28 text-center">
        <h2 class="font-display text-3xl md:text-4xl font-bold text-brand tracking-tight mb-4">
          Klar til at få din AI-synlighed vurderet?
        </h2>
        <p class="text-lg text-gray-500 mb-8 max-w-2xl mx-auto">
          Bestil auditen i dag og få en konkret leverance på dansk, uden abonnement og uden et langt bureauforløb bagefter.
        </p>
        <a href="/kontakt" class="inline-block bg-brand text-white py-4 px-10 font-bold text-lg hover:bg-brand-light transition-colors rounded-md">
          Bestil AI-audit for 2.495 kr
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const included = [
  'AI-synlighed testet på ChatGPT, Gemini, Google AI Overviews og Claude',
  'Gennemgang af 1 website og op til 5 nøglesider',
  'Teknisk baseline for performance, struktur, SEO og sikkerhed',
  'Dansk PDF med score, fund og prioriterede forbedringer',
  'Levering inden for 48 timer på hverdage',
  'Ingen abonnement, ingen binding og ingen skjulte tillæg',
];

const trustBullets = [
  'Sikker betaling via Stripe',
  'Rapporten leveres fra info@sitedokai.com',
  'Levering som PDF, ingen mødekrav bagefter',
];

const orderFlow = [
  'Du udfylder formularen og går til betaling.',
  'Du gennemfører betalingen sikkert via Stripe.',
  'Vi tester website og nøglesider på tværs af AI-platforme og tekniske signaler.',
  'Du modtager rapporten som PDF inden for 48 timer på hverdage.',
];

const faqs = [
  {
    q: 'Hvad koster rapporten?',
    a: 'Rapporten koster 2.495 kr som engangsbeløb. Ingen abonnement. Ingen skjulte gebyrer.',
  },
  {
    q: 'Hvad får jeg konkret?',
    a: 'Du får en færdig PDF-rapport med AI-synlighedsscore, teknisk audit, konkurrentblik og en prioriteret liste over de vigtigste forbedringer.',
  },
  {
    q: 'Skal jeg booke et møde eller en gennemgang?',
    a: 'Nej. Produktet er bevidst enkelt. Du bestiller rapporten, vi leverer rapporten, og så kan du arbejde videre internt eller med din udvikler.',
  },
  {
    q: 'Hvor hurtigt leverer I?',
    a: 'Normalt inden for 48 timer på hverdage. Hvis din side er meget stor eller teknisk sær, siger vi det med det samme.',
  },
];
---

<Layout title="Priser - SitedokAI" description="AI-synlighedsrapport til 2.495 kr. Fast pris, sikker betaling og levering som PDF inden for 48 timer på hverdage.">
  <Nav />
  <main>
    <section class="bg-white border-b border-gray-200">
      <div class="max-w-5xl mx-auto px-6 py-20 md:py-28">
        <div class="max-w-3xl">
          <div class="text-sm font-semibold uppercase tracking-wider text-accent mb-4">Fast pris</div>
          <h1 class="font-display text-4xl md:text-5xl font-extrabold text-brand tracking-tight mb-4">
            AI-synlighedsrapport til 2.495 kr
          </h1>
          <p class="text-lg text-gray-500 leading-relaxed">
            SitedokAI er ét produkt med én fast pris. Du bestiller rapporten, betaler sikkert via Stripe og modtager en dansk PDF med score, fund og prioriterede forbedringer.
          </p>
        </div>
      </div>
    </section>

    <section class="bg-brand text-white border-b border-white/10">
      <div class="max-w-5xl mx-auto px-6 py-20 md:py-28 grid grid-cols-1 lg:grid-cols-[1.05fr_0.95fr] gap-10 items-start">
        <div class="bg-brand-light p-8 md:p-10 ring-2 ring-accent ring-inset rounded-2xl">
          <div class="text-sm font-bold text-white/80 mb-3">SitedokAI Rapport</div>
          <div class="font-display text-4xl md:text-5xl font-extrabold text-white mb-1">2.495 kr</div>
          <div class="text-sm text-white/60 mb-8">Engangskøb, levering inden for 48 timer på hverdage</div>

          <ul class="space-y-3 mb-8">
            {included.map((item) => (
              <li class="flex items-start gap-3 text-sm text-white/70">
                <svg class="w-4 h-4 mt-0.5 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>

          <a href="/kontakt" class="block text-center py-4 px-6 font-bold text-lg bg-amber-400 text-brand hover:bg-amber-300 transition-colors rounded-md mb-5">
            Bestil AI-synlighedsrapport for 2.495 kr
          </a>

          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
            {trustBullets.map((item) => (
              <div class="border border-white/10 bg-white/5 rounded-xl px-4 py-3 text-sm text-white/70 text-center">
                {item}
              </div>
            ))}
          </div>
        </div>

        <div class="space-y-6">
          <div class="bg-white/5 border border-white/10 rounded-2xl p-6 md:p-8">
            <div class="text-sm font-semibold uppercase tracking-wider text-accent-bright mb-3">Hvad sker der efter bestilling?</div>
            <ol class="space-y-4">
              {orderFlow.map((item, index) => (
                <li class="flex items-start gap-4 text-sm text-white/70 leading-relaxed">
                  <span class="w-8 h-8 rounded-full bg-white/10 text-white font-bold flex items-center justify-center flex-shrink-0">{index + 1}</span>
                  <span>{item}</span>
                </li>
              ))}
            </ol>
          </div>

          <div class="bg-white/5 border border-white/10 rounded-2xl p-6 md:p-8">
            <h2 class="font-display text-2xl font-bold text-white mb-4">Vil du se leverancen først?</h2>
            <p class="text-white/70 text-sm leading-relaxed mb-5">
              Se eksempelrapporten og få en konkret fornemmelse af hvordan score, platformsvurderinger og anbefalinger bliver præsenteret.
            </p>
            <a href="/eksempel" class="inline-flex items-center gap-2 text-sm font-bold text-accent-bright hover:text-accent-light transition-colors">
              Se eksempelrapporten
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-white border-b border-gray-200">
      <div class="max-w-3xl mx-auto px-6 py-20 md:py-28">
        <h2 class="font-display text-3xl md:text-4xl font-bold text-brand tracking-tight mb-12">
          Ofte stillede spørgsmål
        </h2>
        <div class="space-y-8">
          {faqs.map((faq) => (
            <div class="border-b border-gray-200 pb-8">
              <h3 class="font-display text-lg font-bold text-brand mb-3">{faq.q}</h3>
              <p class="text-gray-500 leading-relaxed">{faq.a}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-gray-50">
      <div class="max-w-5xl mx-auto px-6 py-20 md:py-28 text-center">
        <h2 class="font-display text-3xl md:text-4xl font-bold text-brand tracking-tight mb-4">
          Klar til at få din AI-synlighed vurderet?
        </h2>
        <p class="text-lg text-gray-500 mb-8 max-w-2xl mx-auto">
          Bestil rapporten i dag og få en konkret leverance på dansk, uden abonnement og uden et langt bureauforløb bagefter.
        </p>
        <a href="/kontakt" class="inline-block bg-amber-400 text-brand py-4 px-10 font-bold text-lg hover:bg-amber-300 transition-colors rounded-md">
          Bestil AI-synlighedsrapport for 2.495 kr
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

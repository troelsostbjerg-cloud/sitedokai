---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const included = [
  'AI-synlighed testet på 5 AI-platforme: ChatGPT, Gemini, Google AI (DK + EN) og Claude',
  '10 tekniske tests: performance, sikkerhed, SEO-basics og Core Web Vitals',
  'Konkurrent-benchmark mod relevante alternativer',
  'Klar PDF-rapport med score, fund og prioriterede forbedringer',
  'Levering inden for 48 timer på hverdage',
  'Ingen abonnement, ingen binding, ingen møder',
];

const faqs = [
  {
    q: 'Hvad koster rapporten?',
    a: 'Rapporten koster 2.495 kr som engangsbeløb. Ingen abonnement. Ingen skjulte gebyrer.',
  },
  {
    q: 'Hvad får jeg konkret?',
    a: 'Du får en færdig PDF-rapport med AI-synlighedsscore, teknisk audit, benchmark mod konkurrenter og en prioriteret liste over de vigtigste forbedringer.',
  },
  {
    q: 'Skal jeg booke et møde eller en gennemgang?',
    a: 'Nej. Produktet er bevidst simpelt. Du bestiller rapporten, vi leverer rapporten, og så er arbejdet færdigt.',
  },
  {
    q: 'Hvor hurtigt leverer I?',
    a: 'Normalt inden for 48 timer på hverdage. Hvis din side er meget stor eller teknisk sær, siger vi det med det samme.',
  },
  {
    q: 'Hjælper I også med at implementere ændringerne?',
    a: 'Nej. SiteDokAI er et rapportprodukt, ikke et bureauforløb. Du får diagnosen og prioriteringen, men implementerer selv eller med din udvikler.',
  },
  {
    q: 'Hvem giver det mening for?',
    a: 'Det giver bedst mening for virksomheder med et rigtigt website og et kommercielt behov for at være synlige i søgning og AI-svar. Især e-commerce, B2B og servicesites.',
  },
];
---

<Layout title="Priser - SitedokAI" description="Én fast pris. Én rapport. 2.495 kr for en komplet AI-synlighedsrapport leveret som PDF.">
  <Nav />
  <main>
    <section class="bg-white border-b border-gray-200">
      <div class="max-w-5xl mx-auto px-6 py-20 md:py-28">
        <div class="max-w-2xl">
          <h1 class="font-display text-4xl md:text-5xl font-extrabold text-brand tracking-tight mb-4">
            Én pris. Én rapport. Færdigt arbejde.
          </h1>
          <p class="text-lg text-gray-500">
            SiteDokAI er ikke et abonnement og ikke et konsulentforløb. Du bestiller en rapport til 2.495 kr, vi leverer rapporten som PDF, og så er den der.
          </p>
        </div>
      </div>
    </section>

    <section class="bg-brand text-white">
      <div class="max-w-5xl mx-auto px-6 py-20 md:py-28">
        <div class="max-w-xl mx-auto bg-brand-light p-8 md:p-10 ring-2 ring-accent ring-inset">
          <div class="text-sm font-bold text-white/80 mb-3">SitedokAI Rapport</div>
          <div class="font-display text-4xl md:text-5xl font-extrabold text-white mb-1">2.495 kr</div>
          <div class="text-sm text-white/40 mb-8">Engangskøb, ingen binding</div>

          <ul class="space-y-3 mb-8">
            {included.map((item) => (
              <li class="flex items-start gap-3 text-sm text-white/70">
                <svg class="w-4 h-4 mt-0.5 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>

          <a
            href="/kontakt"
            class="block text-center py-4 px-6 font-bold text-lg bg-accent text-brand hover:bg-accent-light transition-colors"
          >
            Bestil rapport
          </a>
        </div>
      </div>
    </section>

    <section class="bg-white border-b border-gray-200">
      <div class="max-w-3xl mx-auto px-6 py-20 md:py-28">
        <h2 class="font-display text-3xl md:text-4xl font-bold text-brand tracking-tight mb-12">
          Ofte stillede spørgsmål
        </h2>
        <div class="space-y-8">
          {faqs.map((faq) => (
            <div class="border-b border-gray-200 pb-8">
              <h3 class="font-display text-lg font-bold text-brand mb-3">{faq.q}</h3>
              <p class="text-gray-500 leading-relaxed">{faq.a}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-gray-50">
      <div class="max-w-5xl mx-auto px-6 py-20 md:py-28 text-center">
        <h2 class="font-display text-3xl md:text-4xl font-bold text-brand tracking-tight mb-4">
          Klar til at se hvordan din side ser ud i AI?
        </h2>
        <p class="text-lg text-gray-500 mb-8">
          Bestil rapporten i dag. Du får en klar PDF med fund, score og prioriteter. Ingen møder bagefter.
        </p>
        <a href="/kontakt" class="inline-block bg-amber-400 text-brand py-4 px-10 font-bold text-lg hover:bg-amber-300 transition-colors">
          Bestil rapport — 2.495 kr
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
